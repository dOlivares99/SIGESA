@{
    ViewData["Title"] = "Calendario de disponibilidad";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="fw-bold mb-0">Calendario de disponibilidad</h5>
        <small class="text-muted">Vista mensual y semanal de reservas</small>
    </div>
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="ti ti-list me-1"></i> Ver listado
    </a>
</div>

<!-- Leyenda -->
<div class="d-flex flex-wrap gap-3 mb-3">
    <span class="d-flex align-items-center gap-2 small">
        <span style="width:14px;height:14px;border-radius:4px;background:#6c757d;display:inline-block;"></span>
        Pendiente
    </span>
    <span class="d-flex align-items-center gap-2 small">
        <span style="width:14px;height:14px;border-radius:4px;background:#534AB7;display:inline-block;"></span>
        Confirmada
    </span>
    <span class="d-flex align-items-center gap-2 small">
        <span style="width:14px;height:14px;border-radius:4px;background:#854F0B;display:inline-block;"></span>
        En Proceso
    </span>
    <span class="d-flex align-items-center gap-2 small">
        <span style="width:14px;height:14px;border-radius:4px;background:#0F6E56;display:inline-block;"></span>
        Realizada
    </span>
    <span class="d-flex align-items-center gap-2 small">
        <span style="width:14px;height:14px;border-radius:4px;background:#993C1D;display:inline-block;"></span>
        Cancelada
    </span>
</div>

<div class="card">
    <div class="card-body p-4">
        <div id="calendario"></div>
    </div>
</div>

@section Scripts {
<link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/locales/es.global.min.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const calEl = document.getElementById('calendario');

        const calendar = new FullCalendar.Calendar(calEl, {
            locale: 'es',
            initialView: 'dayGridMonth',
            headerToolbar: {
                left:   'prev,next today',
                center: 'title',
                right:  'dayGridMonth,timeGridWeek'
            },
            buttonText: {
                today:    'Hoy',
                month:    'Mes',
                week:     'Semana'
            },
            height: 'auto',
            events: async function (info, successCallback, failureCallback) {
                try {
                    const res = await fetch("/Reservas/CalendarioData", { credentials: "include" });
                    const data = await res.json();
                    successCallback(data);
                } catch (e) {
                    failureCallback(e);
                }
            },
            eventClick: function (info) {
                const id = info.event.extendedProps.eventoId;
                window.location.href = '/Reservas/Editar/' + id;
            },
            eventMouseEnter: function (info) {
                info.el.style.cursor = 'pointer';
                info.el.title = info.event.title + ' — ' + info.event.extendedProps.estado;
            },
            dayMaxEvents: 3,
            moreLinkText: function (n) { return '+' + n + ' más'; }
        });

        calendar.render();
    });
</script>
}
