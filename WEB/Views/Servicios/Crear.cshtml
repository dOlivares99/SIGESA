@model WEB.Models.ViewModels.ServicioFormViewModel
@{
    ViewData["Title"] = "Nuevo servicio";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="ti ti-arrow-left"></i>
    </a>
    <div>
        <h5 class="fw-bold mb-0">Nuevo servicio</h5>
        <small class="text-muted">Completa los datos del servicio</small>
    </div>
</div>

<div class="row g-4">

    <div class="col-12 col-lg-7">
        <div class="card h-100">
            <div class="card-body p-4">

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger py-2">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div><i class="ti ti-alert-circle me-1"></i>@error.ErrorMessage</div>
                        }
                    </div>
                }

                <form asp-action="Crear" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label fw-medium">Nombre del servicio</label>
                        <input asp-for="Nombre" class="form-control"
                               placeholder="Ej: Sonido profesional" />
                        <span asp-validation-for="Nombre" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Categoria" class="form-label fw-medium">Categoría</label>
                        <input asp-for="Categoria" class="form-control"
                               placeholder="Ej: Audio, Iluminación, Catering..." />
                        <div class="form-text">
                            Los servicios de la misma categoría se agrupan en el catálogo.
                        </div>
                        <span asp-validation-for="Categoria" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="PrecioUnitario" class="form-label fw-medium">
                            Precio unitario (₡)
                        </label>
                        <input asp-for="PrecioUnitario" type="number" step="0.01" min="0.01"
                               class="form-control" placeholder="0.00" />
                        <div class="form-text">El precio debe ser mayor a cero.</div>
                        <span asp-validation-for="PrecioUnitario" class="text-danger small"></span>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="ti ti-device-floppy me-1"></i> Guardar
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>

            </div>
        </div>
    </div>

    <div class="col-12 col-lg-5">
        <div class="card h-100" style="background:#f8f7ff;border:1.5px solid #ece9ff;">
            <div class="card-body p-4">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center"
                         style="width:40px;height:40px;background:#534AB7;">
                        <i class="ti ti-tool text-white"></i>
                    </div>
                    <div>
                        <div class="fw-semibold" style="color:#534AB7;">¿Qué es un servicio?</div>
                        <small class="text-muted">Guía de configuración</small>
                    </div>
                </div>
                <hr style="border-color:#ece9ff;">
                <div class="d-flex align-items-start gap-2 mb-3">
                    <i class="ti ti-circle-check mt-1" style="color:#0F6E56;"></i>
                    <div>
                        <div class="fw-medium small">Nombre único</div>
                        <small class="text-muted">Identifica el servicio dentro de su categoría en el catálogo.</small>
                    </div>
                </div>
                <div class="d-flex align-items-start gap-2 mb-3">
                    <i class="ti ti-circle-check mt-1" style="color:#0F6E56;"></i>
                    <div>
                        <div class="fw-medium small">Categoría</div>
                        <small class="text-muted">Agrupa los servicios por tipo. Ej: Audio, Iluminación, Catering, Decoración.</small>
                    </div>
                </div>
                <div class="d-flex align-items-start gap-2 mb-3">
                    <i class="ti ti-circle-check mt-1" style="color:#0F6E56;"></i>
                    <div>
                        <div class="fw-medium small">Precio unitario</div>
                        <small class="text-muted">Costo por unidad del servicio. Se multiplica por la cantidad al cotizar.</small>
                    </div>
                </div>
                <hr style="border-color:#ece9ff;">
                <div class="d-flex align-items-start gap-2 mt-3">
                    <i class="ti ti-info-circle mt-1" style="color:#534AB7;"></i>
                    <small class="text-muted">
                        El servicio quedará activo de inmediato y disponible para
                        agregar como adicional en nuevas cotizaciones.
                    </small>
                </div>
            </div>
        </div>
    </div>

</div>