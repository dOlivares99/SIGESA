@model List<WEB.Models.ViewModels.ServicioViewModel>
@{
    ViewData["Title"] = "Servicios";
    var categorias = (ViewBag.Categorias as List<string>) ?? new List<string>();
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="fw-bold mb-0">Catálogo de servicios</h5>
        <small class="text-muted">Gestiona los servicios adicionales para eventos</small>
    </div>
    <a asp-action="Crear" class="btn btn-primary btn-sm px-3">
        <i class="ti ti-plus me-1"></i> Nuevo servicio
    </a>
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success py-2">
        <i class="ti ti-circle-check me-1"></i> @TempData["Exito"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger py-2">
        <i class="ti ti-alert-circle me-1"></i> @TempData["Error"]
    </div>
}

<div class="card">
    <div class="card-body">

        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
            <div class="d-flex gap-2">
                <input type="text" id="searchInput" class="form-control form-control-sm"
                       placeholder="Buscar por nombre o categoría..."
                       style="min-width:260px;">
                <select id="statusFilter" class="form-select form-select-sm" style="min-width:140px;">
                    <option value="todos">Todos</option>
                    <option value="activo">Activo</option>
                    <option value="inactivo">Inactivo</option>
                </select>
            </div>
            <small class="text-muted" id="paginationInfo"></small>
        </div>

        <div id="emptyMsg" class="text-center text-muted py-5 d-none">
            <i class="ti ti-search-off" style="font-size:2rem;"></i>
            <p class="mt-2 mb-0">No se encontraron resultados</p>
        </div>

        @foreach (var categoria in categorias)
        {
            var serviciosCategoria = Model.Where(s => s.Categoria == categoria).ToList();
            <div class="categoria-group mb-4" data-categoria="@categoria">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <span class="badge rounded-pill px-3 py-2"
                          style="background:#f0eeff;color:#534AB7;font-size:0.8rem;">
                        <i class="ti ti-tag me-1"></i>@categoria
                    </span>
                    <small class="text-muted grupo-count">@serviciosCategoria.Count servicio(s)</small>
                </div>
                <table class="table table-hover align-middle mb-0 border rounded">
                    <thead style="background:#f8f7ff;">
                        <tr>
                            <th class="ps-4 py-3" style="color:#534AB7;">#</th>
                            <th class="py-3" style="color:#534AB7;">Nombre</th>
                            <th class="py-3" style="color:#534AB7;">Precio unitario</th>
                            <th class="py-3" style="color:#534AB7;">Estado</th>
                            <th class="py-3" style="color:#534AB7;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody class="grupo-tbody">
                        @foreach (var s in serviciosCategoria)
                        {
                            <tr data-nombre="@s.Nombre.ToLower()"
                                data-categoria="@s.Categoria.ToLower()"
                                data-estado="@(s.Activo ? "activo" : "inactivo")"
                                class="@(!s.Activo ? "opacity-50" : "")">
                                <td class="ps-4">@s.ServicioId</td>
                                <td class="fw-medium">@s.Nombre</td>
                                <td>₡@s.PrecioUnitario.ToString("N2")</td>
                                <td>
                                    @if (s.Activo)
                                    {
                                        <span class="badge rounded-pill"
                                              style="background:#e6f4f0;color:#0F6E56;">
                                            <i class="ti ti-circle-check me-1"></i>Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-secondary">Inactivo</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="Editar" asp-route-id="@s.ServicioId"
                                       class="btn btn-sm btn-outline-secondary" title="Editar">
                                        <i class="ti ti-edit"></i>
                                    </a>
                                    <form asp-action="CambiarActivo" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@s.ServicioId" />
                                        <input type="hidden" name="activo"
                                               value="@(!s.Activo ? "true" : "false")" />
                                        <button type="submit"
                                                class="btn btn-sm @(s.Activo ? "btn-outline-danger" : "btn-outline-success")"
                                                title="@(s.Activo ? "Desactivar" : "Activar")"
                                                onclick="return confirm('@(s.Activo ? "¿Desactivar este servicio?" : "¿Activar este servicio?")')">
                                            <i class="ti @(s.Activo ? "ti-toggle-left" : "ti-toggle-right")"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <div class="d-flex justify-content-center mt-3" id="pagination"></div>

    </div>
</div>

@section Scripts {
<script>
    const PAGE_SIZE = 10;
    let currentPage = 1;
    let filteredRows = [];

    const searchInput    = document.getElementById('searchInput');
    const statusFilter   = document.getElementById('statusFilter');
    const grupos         = Array.from(document.querySelectorAll('.categoria-group'));
    const allRows        = Array.from(document.querySelectorAll('.grupo-tbody tr'));
    const pagination     = document.getElementById('pagination');
    const paginationInfo = document.getElementById('paginationInfo');
    const emptyMsg       = document.getElementById('emptyMsg');

    function normalize(str) {
        return str.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');
    }

    function filter() {
        const q      = normalize(searchInput.value.trim());
        const estado = statusFilter.value;

        filteredRows = allRows.filter(r => {
            const matchSearch = !q ||
                normalize(r.dataset.nombre).includes(q) ||
                normalize(r.dataset.categoria).includes(q);
            const matchEstado = estado === 'todos' || r.dataset.estado === estado;
            return matchSearch && matchEstado;
        });

        grupos.forEach(grupo => {
            const tbody   = grupo.querySelector('.grupo-tbody');
            const rows    = Array.from(tbody.querySelectorAll('tr'));
            const visibles = rows.filter(r => filteredRows.includes(r));
            grupo.classList.toggle('d-none', visibles.length === 0);
            const count = grupo.querySelector('.grupo-count');
            if (count) count.textContent = `${visibles.length} servicio(s)`;
        });

        currentPage = 1;
        render();
    }

    function render() {
        const total      = filteredRows.length;
        const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
        currentPage      = Math.min(currentPage, totalPages);
        const start      = (currentPage - 1) * PAGE_SIZE;
        const end        = start + PAGE_SIZE;

        allRows.forEach(r => r.classList.add('d-none'));
        filteredRows.slice(start, end).forEach(r => r.classList.remove('d-none'));

        emptyMsg.classList.toggle('d-none', total > 0);

        paginationInfo.textContent = total > 0
            ? `Mostrando ${Math.min(start + 1, total)}–${Math.min(end, total)} de ${total} servicio${total !== 1 ? 's' : ''}`
            : '';

        pagination.innerHTML = '';
        if (totalPages <= 1) return;

        const ul = document.createElement('ul');
        ul.className = 'pagination pagination-sm mb-0';

        const makeBtn = (label, page, disabled, active) => {
            const li = document.createElement('li');
            li.className = `page-item ${disabled ? 'disabled' : ''} ${active ? 'active' : ''}`;
            const a = document.createElement('a');
            a.className = 'page-link';
            a.href = '#';
            a.innerHTML = label;
            if (active) {
                a.style.background = '#534AB7';
                a.style.borderColor = '#534AB7';
            }
            if (!disabled && !active) {
                a.addEventListener('click', e => {
                    e.preventDefault();
                    currentPage = page;
                    render();
                });
            }
            li.appendChild(a);
            return li;
        };

        ul.appendChild(makeBtn('&laquo;', currentPage - 1, currentPage === 1, false));

        const showPages = [];
        if (currentPage > 3) showPages.push(1, '...');
        for (let i = Math.max(1, currentPage - 2); i <= Math.min(totalPages, currentPage + 2); i++) {
            showPages.push(i);
        }
        if (currentPage < totalPages - 2) showPages.push('...', totalPages);

        showPages.forEach(p => {
            if (p === '...') {
                const li = document.createElement('li');
                li.className = 'page-item disabled';
                li.innerHTML = '<a class="page-link">…</a>';
                ul.appendChild(li);
            } else {
                ul.appendChild(makeBtn(p, p, false, p === currentPage));
            }
        });

        ul.appendChild(makeBtn('&raquo;', currentPage + 1, currentPage === totalPages, false));
        pagination.appendChild(ul);
    }

    searchInput.addEventListener('input', filter);
    statusFilter.addEventListener('change', filter);
    filter();
</script>
}
