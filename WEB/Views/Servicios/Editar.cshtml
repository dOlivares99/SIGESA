@model WEB.Models.ViewModels.ServicioFormViewModel
@{
    ViewData["Title"] = "Editar servicio";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="ti ti-arrow-left"></i>
    </a>
    <div>
        <h5 class="fw-bold mb-0">Editar servicio</h5>
        <small class="text-muted">Modifica los datos del servicio</small>
    </div>
</div>

<div class="card" style="max-width:560px;">
    <div class="card-body p-4">

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger py-2">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div><i class="ti ti-alert-circle me-1"></i>@error.ErrorMessage</div>
                }
            </div>
        }

        <form asp-action="Editar" asp-route-id="@Model.ServicioId" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="Nombre" class="form-label fw-medium">Nombre del servicio</label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Categoria" class="form-label fw-medium">Categoría</label>
                <input asp-for="Categoria" class="form-control" />
                <span asp-validation-for="Categoria" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="PrecioUnitario" class="form-label fw-medium">
                    Precio unitario (₡)
                </label>
                <input asp-for="PrecioUnitario" type="number" step="0.01" min="0.01"
                       class="form-control" />
                <div class="form-text">El precio debe ser mayor a cero.</div>
                <span asp-validation-for="PrecioUnitario" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="ti ti-device-floppy me-1"></i> Guardar cambios
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>