@model List<WEB.Models.ViewModels.PagoViewModel>
@{
    ViewData["Title"] = "Pagos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="fw-bold mb-0">Pagos</h5>
        <small class="text-muted">Historial de pagos registrados</small>
    </div>
    <a asp-action="Crear" class="btn btn-primary btn-sm px-3">
        <i class="ti ti-plus me-1"></i> Registrar pago
    </a>
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success py-2 mb-3">
        <i class="ti ti-circle-check me-1"></i>@TempData["Exito"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger py-2 mb-3">
        <i class="ti ti-alert-circle me-1"></i>@TempData["Error"]
    </div>
}
@if (ViewBag.Error != null)
{
    <div class="alert alert-danger py-2 mb-3">
        <i class="ti ti-alert-circle me-1"></i>@ViewBag.Error
    </div>
}

<div class="card">
    <div class="card-body">

        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
            <div class="d-flex gap-2 flex-wrap align-items-center">
                <input type="text" id="searchInput" class="form-control form-control-sm"
                       placeholder="Buscar por cliente, evento, tipo o método..."
                       style="min-width:260px;">
                <input type="date" id="filtroFechaDesde" class="form-control form-control-sm"
                       style="width:auto;" title="Desde">
                <input type="date" id="filtroFechaHasta" class="form-control form-control-sm"
                       style="width:auto;" title="Hasta">
                <button type="button" class="btn btn-sm btn-outline-secondary" onclick="limpiarFiltros()">
                    <i class="ti ti-x me-1"></i> Limpiar
                </button>
            </div>
            <small class="text-muted" id="paginationInfo"></small>
        </div>

        <table class="table table-hover align-middle mb-0" id="mainTable">
            <thead style="background:#f8f7ff;">
                <tr>
                    <th class="ps-3 py-3" style="color:#534AB7;">#</th>
                    <th class="py-3" style="color:#534AB7;">Cliente</th>
                    <th class="py-3" style="color:#534AB7;">Evento</th>
                    <th class="py-3" style="color:#534AB7;">Tipo</th>
                    <th class="py-3" style="color:#534AB7;">Método</th>
                    <th class="py-3" style="color:#534AB7;">Monto</th>
                    <th class="py-3" style="color:#534AB7;">Fecha</th>
                    <th class="py-3" style="color:#534AB7;">Comprobante</th>
                    <th class="py-3" style="color:#534AB7;">Acciones</th>
                </tr>
            </thead>
            <tbody id="tableBody">
                @foreach (var p in Model)
                {
                    <tr data-cliente="@p.ClienteNombre.ToLower()"
                        data-evento="@p.TipoEvento.ToLower()"
                        data-tipo="@p.TipoPagoNombre.ToLower()"
                        data-metodo="@p.MetodoPagoNombre.ToLower()"
                        data-fecha="@p.FechaPago.ToString("yyyy-MM-dd")">
                        <td class="ps-3 text-muted small">@p.PagoId</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold"
                                     style="width:32px;height:32px;background:#f0eeff;color:#534AB7;font-size:0.8rem;flex-shrink:0;">
                                    @(p.ClienteNombre.Length > 0 ? p.ClienteNombre[0].ToString().ToUpper() : "?")
                                </div>
                                <span class="fw-medium">@p.ClienteNombre</span>
                            </div>
                        </td>
                        <td class="text-muted small">@p.TipoEvento</td>
                        <td>
                            <span class="badge rounded-pill px-3" style="background:#f0eeff;color:#534AB7;">
                                @p.TipoPagoNombre
                            </span>
                        </td>
                        <td class="text-muted small">@p.MetodoPagoNombre</td>
                        <td class="fw-medium">₡@p.Monto.ToString("N2")</td>
                        <td class="text-muted small">@p.FechaPago.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (!string.IsNullOrEmpty(p.UrlComprobante))
                            {
                                <a href="@p.UrlComprobante" target="_blank"
                                   class="btn btn-sm btn-outline-primary" title="Ver comprobante">
                                    <i class="ti ti-photo"></i>
                                </a>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td>
                            <button type="button"
                                    class="btn btn-sm btn-outline-danger"
                                    title="Eliminar"
                                    onclick="confirmarEliminar(@p.PagoId, '@p.ClienteNombre — ₡@p.Monto.ToString("N2")')">
                                <i class="ti ti-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div id="emptyMsg" class="text-center text-muted py-5 d-none">
            <i class="ti ti-cash-off" style="font-size:2rem;"></i>
            <p class="mt-2 mb-0">No se encontraron pagos</p>
        </div>

        <div class="d-flex flex-column align-items-center mt-3 gap-1">
            <div id="pagination"></div>
            <small class="text-muted" id="paginationInfoBottom"></small>
        </div>

    </div>
</div>

<!-- Modal eliminar -->
<div class="modal fade" id="modalEliminar" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:16px;border:none;">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold">Eliminar pago</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted mb-0">
                    ¿Deseas eliminar el pago de <strong id="nombreEliminar"></strong>?
                    El saldo del evento se recalculará. Esta acción no se puede deshacer.
                </p>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancelar</button>
                <form id="formEliminar" method="post" style="display:inline;">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger btn-sm">
                        <i class="ti ti-trash me-1"></i> Eliminar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const PAGE_SIZE = 10;
    let currentPage = 1;
    let filteredRows = [];

    const searchInput       = document.getElementById('searchInput');
    const filtroFechaDesde  = document.getElementById('filtroFechaDesde');
    const filtroFechaHasta  = document.getElementById('filtroFechaHasta');
    const tableBody         = document.getElementById('tableBody');
    const allRows           = Array.from(tableBody.querySelectorAll('tr'));
    const pagination        = document.getElementById('pagination');
    const paginationInfo    = document.getElementById('paginationInfo');
    const paginationInfoBot = document.getElementById('paginationInfoBottom');
    const emptyMsg          = document.getElementById('emptyMsg');

    function normalize(str) {
        return str.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
    }

    function limpiarFiltros() {
        searchInput.value      = '';
        filtroFechaDesde.value = '';
        filtroFechaHasta.value = '';
        filter();
    }

    function filter() {
        const q     = normalize(searchInput.value.trim());
        const desde = filtroFechaDesde.value;
        const hasta = filtroFechaHasta.value;

        filteredRows = allRows.filter(r => {
            const matchQ = !q ||
                normalize(r.dataset.cliente).includes(q) ||
                normalize(r.dataset.evento).includes(q) ||
                normalize(r.dataset.tipo).includes(q) ||
                normalize(r.dataset.metodo).includes(q);
            const fecha = r.dataset.fecha;
            const matchDesde = !desde || fecha >= desde;
            const matchHasta = !hasta || fecha <= hasta;
            return matchQ && matchDesde && matchHasta;
        });

        currentPage = 1;
        render();
    }

    function render() {
        const total      = filteredRows.length;
        const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
        currentPage      = Math.min(currentPage, totalPages);
        const start      = (currentPage - 1) * PAGE_SIZE;
        const end        = start + PAGE_SIZE;

        allRows.forEach(r => r.classList.add('d-none'));
        filteredRows.slice(start, end).forEach(r => r.classList.remove('d-none'));

        emptyMsg.classList.toggle('d-none', total > 0);

        const info = total > 0
            ? `Mostrando ${Math.min(start+1,total)}–${Math.min(end,total)} de ${total} pago${total !== 1 ? 's' : ''}`
            : '';
        paginationInfo.textContent    = info;
        paginationInfoBot.textContent = info;

        pagination.innerHTML = '';
        if (totalPages <= 1) return;

        const ul = document.createElement('ul');
        ul.className = 'pagination pagination-sm mb-0';

        const makeBtn = (label, page, disabled, active) => {
            const li = document.createElement('li');
            li.className = `page-item ${disabled ? 'disabled' : ''} ${active ? 'active' : ''}`;
            const a = document.createElement('a');
            a.className = 'page-link';
            a.href = '#';
            a.innerHTML = label;
            if (active) { a.style.background = '#534AB7'; a.style.borderColor = '#534AB7'; }
            if (!disabled && !active)
                a.addEventListener('click', e => { e.preventDefault(); currentPage = page; render(); });
            li.appendChild(a);
            return li;
        };

        ul.appendChild(makeBtn('&laquo;', currentPage-1, currentPage===1, false));

        const showPages = [];
        if (currentPage > 3) showPages.push(1, '...');
        for (let i = Math.max(1,currentPage-2); i <= Math.min(totalPages,currentPage+2); i++)
            showPages.push(i);
        if (currentPage < totalPages - 2) showPages.push('...', totalPages);

        showPages.forEach(p => {
            if (p === '...') {
                const li = document.createElement('li');
                li.className = 'page-item disabled';
                li.innerHTML = '<a class="page-link">…</a>';
                ul.appendChild(li);
            } else {
                ul.appendChild(makeBtn(p, p, false, p === currentPage));
            }
        });

        ul.appendChild(makeBtn('&raquo;', currentPage+1, currentPage===totalPages, false));
        pagination.appendChild(ul);
    }

    searchInput.addEventListener('input', filter);
    filtroFechaDesde.addEventListener('change', filter);
    filtroFechaHasta.addEventListener('change', filter);
    filter();

    function confirmarEliminar(id, nombre) {
        document.getElementById('nombreEliminar').textContent = nombre;
        document.getElementById('formEliminar').action = '/Pagos/Eliminar/' + id;
        new bootstrap.Modal(document.getElementById('modalEliminar')).show();
    }
</script>
}
