<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — SIGESA</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/tabler-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        * { font-family: 'Inter', sans-serif; }
        body { background-color: #F5F4EF; }

        /* Sidebar */
        .sidebar {
            width: 240px;
            min-height: 100vh;
            background: linear-gradient(180deg, #534AB7 0%, #3d3490 100%);
            position: fixed;
            top: 0; left: 0;
            padding: 1.5rem 1rem;
            z-index: 100;
        }
        .sidebar .brand {
            color: white;
            font-weight: 700;
            font-size: 1.25rem;
            padding: 0.5rem 0.75rem 1.5rem;
            border-bottom: 1px solid rgba(255,255,255,0.15);
            margin-bottom: 1rem;
        }
        .sidebar .brand small {
            display: block;
            font-size: 0.7rem;
            font-weight: 400;
            opacity: 0.7;
        }
        .sidebar .nav-link {
            color: rgba(255,255,255,0.75);
            border-radius: 10px;
            padding: 0.6rem 0.75rem;
            font-size: 0.875rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            transition: all 0.15s;
        }
        .sidebar .nav-link:hover,
        .sidebar .nav-link.active {
            background: rgba(255,255,255,0.15);
            color: white;
        }
        .sidebar .nav-section {
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: rgba(255,255,255,0.4);
            padding: 1rem 0.75rem 0.25rem;
        }

        /* Main content */
        .main-content {
            margin-left: 240px;
            padding: 1.5rem;
            min-height: 100vh;
        }

        /* Topbar */
        .topbar {
            background: white;
            border-radius: 12px;
            padding: 0.75rem 1.25rem;
            margin-bottom: 1.5rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 1px 4px rgba(0,0,0,0.06);
        }
        .topbar .page-title {
            font-weight: 600;
            font-size: 1rem;
            color: #1E1E1E;
        }
        .topbar .user-info {
            font-size: 0.825rem;
            color: #555;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        /* Cards */
        .card {
            border: none;
            border-radius: 16px;
            box-shadow: 0 1px 4px rgba(0,0,0,0.06);
        }

        /* Buttons */
        .btn-primary { background-color: #534AB7; border-color: #534AB7; }
        .btn-primary:hover { background-color: #4239a0; border-color: #4239a0; }
        .btn-outline-primary { color: #534AB7; border-color: #534AB7; }
        .btn-outline-primary:hover { background-color: #534AB7; color: white; }

        /* Badges */
        .badge-activo { background-color: #0F6E56; }
        .badge-pendiente { background-color: #854F0B; }
        .badge-cancelado { background-color: #993C1D; }

        /* Alerts */
        .alert-success { background-color: #e6f4f0; border-color: #0F6E56; color: #0F6E56; }
        .alert-danger  { background-color: #fdf0ed; border-color: #993C1D; color: #993C1D; }
        .alert-warning { background-color: #fdf5e6; border-color: #854F0B; color: #854F0B; }

        /* Solo Admin */
        .admin-only { display: none; }
        .rol-administrador .admin-only { display: flex; }
    </style>
</head>
<body class="rol-@(Context.Session.GetString("RolNombre")?.ToLower() ?? "")">

    <!-- Sidebar -->
    <div class="sidebar">
        <div class="brand">
            SIGESA
            <small>Sala de Eventos Mónica</small>
        </div>

        <nav>
            <div class="nav-section">Principal</div>
            <a asp-controller="Home" asp-action="Index"
               class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                <i class="ti ti-dashboard"></i> Dashboard
            </a>

            <div class="nav-section">Gestión</div>
            <a asp-controller="Reservas" asp-action="Index"
               class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reservas" ? "active" : "")">
                <i class="ti ti-calendar-event"></i> Reservas
            </a>
            <a asp-controller="Clientes" asp-action="Index"
               class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Clientes" ? "active" : "")">
                <i class="ti ti-users"></i> Clientes
            </a>
            <a asp-controller="Cotizaciones" asp-action="Index"
               class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Cotizaciones" ? "active" : "")">
                <i class="ti ti-file-invoice"></i> Cotizaciones
            </a>
            <a asp-controller="Pagos" asp-action="Index"
               class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Pagos" ? "active" : "")">
                <i class="ti ti-cash"></i> Pagos
            </a>

            <div class="nav-section admin-only">Configuración</div>
            <a asp-controller="Usuarios" asp-action="Index"
               class="nav-link admin-only @(ViewContext.RouteData.Values["controller"]?.ToString() == "Usuarios" ? "active" : "")">
                <i class="ti ti-user-cog"></i> Usuarios
            </a>
            <a asp-controller="Paquetes" asp-action="Index"
               class="nav-link admin-only @(ViewContext.RouteData.Values["controller"]?.ToString() == "Paquetes" ? "active" : "")">
                <i class="ti ti-package"></i> Paquetes
            </a>
            <a asp-controller="Servicios" asp-action="Index"
               class="nav-link admin-only @(ViewContext.RouteData.Values["controller"]?.ToString() == "Servicios" ? "active" : "")">
                <i class="ti ti-tool"></i> Servicios
            </a>
        </nav>
    </div>

    <!-- Main -->
    <div class="main-content">
        <!-- Topbar -->
        <div class="topbar">
            <span class="page-title">@ViewData["Title"]</span>
            <div class="user-info">
                <i class="ti ti-user-circle"></i>
                @Context.Session.GetString("UsuarioNombre")
                <span class="badge bg-secondary ms-1" style="font-size:0.7rem;">
                    @Context.Session.GetString("RolNombre")
                </span>
                <a asp-controller="Auth" asp-action="Logout"
                   class="btn btn-sm btn-outline-secondary ms-2" style="font-size:0.75rem;">
                    <i class="ti ti-logout"></i> Salir
                </a>
            </div>
        </div>

        <!-- Alerts globales -->
        @if (TempData["Exito"] != null)
        {
            <div class="alert alert-success mb-3">
                <i class="ti ti-circle-check me-1"></i> @TempData["Exito"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger mb-3">
                <i class="ti ti-alert-circle me-1"></i> @TempData["Error"]
            </div>
        }

        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
