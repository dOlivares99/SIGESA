<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — SIGESA</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/tabler-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
            * {
                font-family: 'Inter', sans-serif;
            }

            body {
                background-color: #F5F4EF;
            }

            /* Sidebar */
            .sidebar {
                width: 240px;
                min-height: 100vh;
                background: linear-gradient(180deg, #534AB7 0%, #3d3490 100%);
                position: fixed;
                top: 0;
                left: 0;
                padding: 1.5rem 1rem;
                z-index: 100;
            }

                .sidebar .brand {
                    color: white;
                    font-weight: 700;
                    font-size: 1.25rem;
                    padding: 0.5rem 0.75rem 1.5rem;
                    border-bottom: 1px solid rgba(255,255,255,0.15);
                    margin-bottom: 1rem;
                }

                    .sidebar .brand small {
                        display: block;
                        font-size: 0.7rem;
                        font-weight: 400;
                        opacity: 0.7;
                    }

                .sidebar .nav-link {
                    color: rgba(255,255,255,0.75);
                    border-radius: 10px;
                    padding: 0.6rem 0.75rem;
                    font-size: 0.875rem;
                    display: flex;
                    align-items: center;
                    gap: 0.5rem;
                    transition: all 0.15s;
                }

                    .sidebar .nav-link:hover,
                    .sidebar .nav-link.active {
                        background: rgba(255,255,255,0.15);
                        color: white;
                    }

                .sidebar .nav-section {
                    font-size: 0.7rem;
                    text-transform: uppercase;
                    letter-spacing: 0.08em;
                    color: rgba(255,255,255,0.4);
                    padding: 1rem 0.75rem 0.25rem;
                }

            /* Main content */
            .main-content {
                margin-left: 240px;
                padding: 1.5rem;
                min-height: 100vh;
            }

            /* Topbar */
            .topbar {
                background: white;
                border-radius: 12px;
                padding: 0.75rem 1.25rem;
                margin-bottom: 1.5rem;
                display: flex;
                justify-content: flex-end;
                align-items: center;
                box-shadow: 0 1px 4px rgba(0,0,0,0.06);
            }

                .topbar .user-info {
                    font-size: 0.825rem;
                    color: #555;
                    display: flex;
                    align-items: center;
                    gap: 0.5rem;
                }

            /* Cards */
            .card {
                border: none;
                border-radius: 16px;
                box-shadow: 0 1px 4px rgba(0,0,0,0.06);
            }

            /* Buttons */
            .btn-primary {
                background-color: #534AB7;
                border-color: #534AB7;
            }

                .btn-primary:hover {
                    background-color: #4239a0;
                    border-color: #4239a0;
                }

            .btn-outline-primary {
                color: #534AB7;
                border-color: #534AB7;
            }

                .btn-outline-primary:hover {
                    background-color: #534AB7;
                    color: white;
                }

            /* Badges */
            .badge-activo {
                background-color: #0F6E56;
            }

            .badge-pendiente {
                background-color: #854F0B;
            }

            .badge-cancelado {
                background-color: #993C1D;
            }

            /* Alerts */
            .alert-success {
                background-color: #e6f4f0;
                border-color: #0F6E56;
                color: #0F6E56;
            }

            .alert-danger {
                background-color: #fdf0ed;
                border-color: #993C1D;
                color: #993C1D;
            }

            .alert-warning {
                background-color: #fdf5e6;
                border-color: #854F0B;
                color: #854F0B;
            }

            /* Solo Admin */
            .admin-only {
                display: none;
            }

            .rol-administrador .admin-only {
                display: flex;
            }

            /* Toast container */
            .toast-container {
                position: fixed;
                top: 1.5rem;
                left: 50%;
                transform: translateX(-50%);
                z-index: 9999;
                display: flex;
                flex-direction: column;
                align-items: center;
                gap: 0.5rem;
            }

            /* Toasts personalizados */
            .toast-sigesa {
                min-width: 300px;
                max-width: 380px;
                border: none;
                border-radius: 12px;
                box-shadow: 0 4px 16px rgba(0,0,0,0.12);
                overflow: hidden;
                opacity: 1;
                transition: opacity 0.3s ease;
            }

                .toast-sigesa .toast-header {
                    border-bottom: none;
                    padding: 0.65rem 0.85rem 0;
                    font-size: 0.8rem;
                    font-weight: 600;
                    display: flex;
                    align-items: center;
                    gap: 0.4rem;
                }

                .toast-sigesa .toast-body {
                    padding: 0.25rem 0.85rem 0.75rem;
                    font-size: 0.85rem;
                }

                /* Botón cerrar custom */
                .toast-sigesa .toast-close {
                    margin-left: auto;
                    background: none;
                    border: none;
                    cursor: pointer;
                    font-size: 1rem;
                    line-height: 1;
                    padding: 0 0 0 0.5rem;
                    opacity: 0.6;
                    transition: opacity 0.15s;
                }

                    .toast-sigesa .toast-close:hover {
                        opacity: 1;
                    }

                /* Variantes de color */
                .toast-sigesa.toast-success,
                .toast-sigesa.toast-success .toast-header,
                .toast-sigesa.toast-success .toast-body {
                    background-color: #e6f4f0;
                    color: #0F6E56;
                }

                    .toast-sigesa.toast-success .toast-close {
                        color: #0F6E56;
                    }

                .toast-sigesa.toast-error,
                .toast-sigesa.toast-error .toast-header,
                .toast-sigesa.toast-error .toast-body {
                    background-color: #fdf0ed;
                    color: #993C1D;
                }

                    .toast-sigesa.toast-error .toast-close {
                        color: #993C1D;
                    }

                .toast-sigesa.toast-warning,
                .toast-sigesa.toast-warning .toast-header,
                .toast-sigesa.toast-warning .toast-body {
                    background-color: #fdf5e6;
                    color: #854F0B;
                }

                    .toast-sigesa.toast-warning .toast-close {
                        color: #854F0B;
                    }
    </style>
</head>
<body class="rol-@(Context.Session.GetString("RolNombre")?.ToLower() ?? "")">

    <!-- Sidebar -->
    <div class="sidebar">
        <div class="brand">
            SIGESA
            <small>Sala de Eventos Mónica</small>
        </div>

        <nav>
            <div class="nav-section">Principal</div>
            <a asp-controller="Home" asp-action="Index"
               class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                <i class="ti ti-dashboard"></i> Dashboard
            </a>

            <div class="nav-section">Gestión</div>
            <a asp-controller="Reservas" asp-action="Index"
               class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reservas" ? "active" : "")">
                <i class="ti ti-calendar-event"></i> Reservas
            </a>
            <a asp-controller="Clientes" asp-action="Index"
               class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Clientes" ? "active" : "")">
                <i class="ti ti-users"></i> Clientes
            </a>
            <a asp-controller="Cotizaciones" asp-action="Index"
               class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Cotizaciones" ? "active" : "")">
                <i class="ti ti-file-invoice"></i> Cotizaciones
            </a>
            <a asp-controller="Pagos" asp-action="Index"
               class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Pagos" ? "active" : "")">
                <i class="ti ti-cash"></i> Pagos
            </a>

            <div class="nav-section admin-only">Configuración</div>
            <a asp-controller="Usuarios" asp-action="Index"
               class="nav-link admin-only @(ViewContext.RouteData.Values["controller"]?.ToString() == "Usuarios" ? "active" : "")">
                <i class="ti ti-user-cog"></i> Usuarios
            </a>
            <a asp-controller="Paquetes" asp-action="Index"
               class="nav-link admin-only @(ViewContext.RouteData.Values["controller"]?.ToString() == "Paquetes" ? "active" : "")">
                <i class="ti ti-package"></i> Paquetes
            </a>
            <a asp-controller="Servicios" asp-action="Index"
               class="nav-link admin-only @(ViewContext.RouteData.Values["controller"]?.ToString() == "Servicios" ? "active" : "")">
                <i class="ti ti-tool"></i> Servicios
            </a>
        </nav>
    </div>

    <!-- Main -->
    <div class="main-content">
        <!-- Topbar -->
        <div class="topbar">
            <div class="user-info">
                <i class="ti ti-user-circle"></i>
                @Context.Session.GetString("UsuarioNombre")
                <span class="badge bg-secondary ms-1" style="font-size:0.7rem;">
                    @Context.Session.GetString("RolNombre")
                </span>
                <a asp-controller="Auth" asp-action="Logout"
                   class="btn btn-sm btn-outline-secondary ms-2" style="font-size:0.75rem;">
                    <i class="ti ti-logout"></i> Salir
                </a>
            </div>
        </div>

        @RenderBody()
    </div>

   
    <div class="toast-container" id="toastContainer"></div>

    
    @if (TempData["Exito"] != null)
    {
        <span id="toast-exito" data-msg="@TempData["Exito"]" class="d-none"></span>
    }
    @if (TempData["Error"] != null)
    {
        <span id="toast-error" data-msg="@TempData["Error"]" class="d-none"></span>
    }
    @if (TempData["Advertencia"] != null)
    {
        <span id="toast-advertencia" data-msg="@TempData["Advertencia"]" class="d-none"></span>
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        function showToast(type, icon, title, message) {
        const container = document.getElementById('toastContainer');

        const toast = document.createElement('div');
        toast.className = `toast-sigesa toast-${type}`;
        toast.innerHTML = `
        <div class="toast-header">
        <i class="ti ${icon}"></i>
        <strong class="me-auto ms-1">${title}</strong>
        <button class="toast-close" title="Cerrar">&#x2715;</button>
        </div>
        <div class="toast-body">${message}</div>
        `;

        const cerrar = () => {
        toast.style.opacity = '0';
        setTimeout(() => toast.remove(), 300);
        };

        toast.querySelector('.toast-close').addEventListener('click', cerrar);
        container.appendChild(toast);

        
        setTimeout(cerrar, 4000);
        }

        document.addEventListener('DOMContentLoaded', () => {
        const exito = document.getElementById('toast-exito');
        if (exito) showToast('success', 'ti-circle-check', 'Éxito', exito.dataset.msg);

        const error = document.getElementById('toast-error');
        if (error) showToast('error', 'ti-alert-circle', 'Error', error.dataset.msg);

        const adv = document.getElementById('toast-advertencia');
        if (adv) showToast('warning', 'ti-alert-triangle', 'Atención', adv.dataset.msg);
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>