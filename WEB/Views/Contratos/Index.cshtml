@model IEnumerable<WEB.Models.ViewModels.ContratoViewModel>

@{
    ViewData["Title"] = "Contratos";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="fw-bold mb-0">Contratos</h5>
        <small class="text-muted">
            Gestiona los contratos generados a partir de las cotizaciones
        </small>
    </div>

    <a asp-action="Crear"
       class="btn btn-primary btn-sm px-3">
        <i class="ti ti-plus me-1"></i>
        Nuevo contrato
    </a>
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success alert-dismissible fade show"
         role="alert">
        <i class="ti ti-circle-check me-1"></i>
        @TempData["Exito"]

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert"
                aria-label="Cerrar">
        </button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show"
         role="alert">
        <i class="ti ti-alert-circle me-1"></i>
        @TempData["Error"]

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert"
                aria-label="Cerrar">
        </button>
    </div>
}

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger"
         role="alert">
        <i class="ti ti-alert-circle me-1"></i>
        @ViewBag.Error
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="card-body">

        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
            <div class="d-flex flex-wrap gap-2">

                <input type="text"
                       id="searchInput"
                       class="form-control form-control-sm"
                       placeholder="Buscar por cliente, contrato o evento..."
                       style="min-width:260px;" />

                <select id="statusFilter"
                        class="form-select form-select-sm"
                        style="min-width:170px;">

                    <option value="todos">Todos los estados</option>
                    <option value="pendiente">Pendiente</option>
                    <option value="firmado">Firmado</option>
                    <option value="cancelado">Cancelado</option>
                    <option value="anulado">Anulado</option>
                </select>
            </div>

            <small class="text-muted"
                   id="paginationInfo">
            </small>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0"
                   id="mainTable">

                <thead style="background:#f8f7ff;">
                    <tr>
                        <th class="ps-3 py-3"
                            style="color:#534AB7;">
                            Número
                        </th>

                        <th class="py-3"
                            style="color:#534AB7;">
                            Cliente
                        </th>

                        <th class="py-3"
                            style="color:#534AB7;">
                            Evento
                        </th>

                        <th class="py-3"
                            style="color:#534AB7;">
                            Fecha del evento
                        </th>

                        <th class="py-3"
                            style="color:#534AB7;">
                            Total
                        </th>

                        <th class="py-3"
                            style="color:#534AB7;">
                            Estado
                        </th>

                        <th class="py-3"
                            style="color:#534AB7;">
                            Fecha contrato
                        </th>

                        <th class="py-3 text-center"
                            style="color:#534AB7;">
                            Acciones
                        </th>
                    </tr>
                </thead>

                <tbody id="tableBody">

                    @if (Model != null)
                    {
                        @foreach (var contrato in Model)
                        {
                            var estadoKey =
                                (contrato.Estado ?? "")
                                .Trim()
                                .ToLowerInvariant();

                            var estadoBg = "#fff8e6";
                            var estadoColor = "#854F0B";

                            switch (estadoKey)
                            {
                                case "firmado":
                                    estadoBg = "#e6f4f0";
                                    estadoColor = "#0F6E56";
                                    break;

                                case "cancelado":
                                    estadoBg = "#ffeee8";
                                    estadoColor = "#993C1D";
                                    break;

                                case "anulado":
                                    estadoBg = "#f0f0f0";
                                    estadoColor = "#555555";
                                    break;

                                case "pendiente":
                                    estadoBg = "#fff8e6";
                                    estadoColor = "#854F0B";
                                    break;
                            }

                            var clienteNombre =
                                string.IsNullOrWhiteSpace(
                                    contrato.ClienteNombre)
                                    ? "Sin cliente"
                                    : contrato.ClienteNombre;

                            var tipoEvento =
                                string.IsNullOrWhiteSpace(
                                    contrato.TipoEvento)
                                    ? "Sin tipo"
                                    : contrato.TipoEvento;

                            var numeroContrato =
                                string.IsNullOrWhiteSpace(
                                    contrato.NumeroContrato)
                                    ? contrato.ContratoId.ToString()
                                    : contrato.NumeroContrato;

                            var inicialCliente =
                                clienteNombre.Length > 0
                                    ? clienteNombre
                                        .Substring(0, 1)
                                        .ToUpper()
                                    : "?";

                            <tr data-cliente="@clienteNombre.ToLowerInvariant()"
                                data-tipo="@tipoEvento.ToLowerInvariant()"
                                data-numero="@numeroContrato.ToLowerInvariant()"
                                data-estado="@estadoKey">

                                <td class="ps-3 fw-medium">
                                    @numeroContrato
                                </td>

                                <td>
                                    <div class="d-flex align-items-center gap-2">

                                        <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold"
                                             style="width:32px;
                                            height:32px;
                                            min-width:32px;
                                            background:#f0eeff;
                                            color:#534AB7;
                                            font-size:0.8rem;">
                                            @inicialCliente
                                        </div>

                                        <span class="fw-medium">
                                            @clienteNombre
                                        </span>
                                    </div>
                                </td>

                                <td class="text-muted small">
                                    @tipoEvento
                                </td>

                                <td class="text-muted small">
                                    @if (contrato.FechaEvento != DateTime.MinValue)
                                    {
                                        @contrato.FechaEvento.ToString("dd/MM/yyyy")
                                    }
                                    else
                                    {
                                        <span>Sin fecha</span>
                                    }
                                </td>

                                <td class="fw-medium">
                                    ₡@contrato.Total.ToString("N2")
                                </td>

                                <td>
                                    <span class="badge rounded-pill px-3"
                                          style="background:@estadoBg;
                                        color:@estadoColor;">
                                        @contrato.Estado
                                    </span>
                                </td>

                                <td class="text-muted small">
                                    @(contrato.FechaContrato.ToString("dd/MM/yyyy"))
                                </td>

                                <td>
                                    <div class="d-flex justify-content-center flex-wrap gap-1">

                                        <a asp-action="Detalles"
                                           asp-route-id="@contrato.ContratoId"
                                           class="btn btn-sm btn-outline-secondary"
                                           title="Ver detalles">
                                            <i class="ti ti-eye"></i>
                                        </a>

                                        <a asp-action="Editar"
                                           asp-route-id="@contrato.ContratoId"
                                           class="btn btn-sm btn-outline-primary"
                                           title="Editar contrato">
                                            <i class="ti ti-edit"></i>
                                        </a>

                                        <a asp-action="DescargarPdf"
                                           asp-route-id="@contrato.ContratoId"
                                           class="btn btn-sm btn-outline-danger"
                                           title="Descargar PDF"
                                           target="_blank">
                                            <i class="ti ti-file-type-pdf"></i>
                                        </a>

                                        <form asp-action="Enviar"
                                              asp-route-id="@contrato.ContratoId"
                                              method="post"
                                              class="d-inline">

                                            @Html.AntiForgeryToken()

                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-success"
                                                    title="Enviar por correo"
                                                    onclick="return confirm('¿Desea enviar este contrato al cliente?');">
                                                <i class="ti ti-mail-forward"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>

        <div id="emptyMsg"
             class="text-center text-muted py-5 d-none">

            <i class="ti ti-search-off"
               style="font-size:2rem;">
            </i>

            <p class="mt-2 mb-0">
                No se encontraron contratos
            </p>
        </div>

        <div class="d-flex justify-content-center mt-3"
             id="pagination">
        </div>
    </div>
</div>

@section Scripts
{
    <script>
        const PAGE_SIZE = 10;

        let currentPage = 1;
        let filteredRows = [];

        const searchInput =
            document.getElementById('searchInput');

        const statusFilter =
            document.getElementById('statusFilter');

        const tableBody =
            document.getElementById('tableBody');

        const allRows =
            Array.from(
                tableBody.querySelectorAll('tr'));

        const pagination =
            document.getElementById('pagination');

        const paginationInfo =
            document.getElementById('paginationInfo');

        const emptyMsg =
            document.getElementById('emptyMsg');

        function normalize(value) {
            return (value || '')
                .toLowerCase()
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '');
        }

        function filter() {
            const query =
                normalize(searchInput.value.trim());

            const estado =
                normalize(statusFilter.value);

            filteredRows = allRows.filter(row => {
                const cliente =
                    normalize(row.dataset.cliente);

                const tipo =
                    normalize(row.dataset.tipo);

                const numero =
                    normalize(row.dataset.numero);

                const estadoFila =
                    normalize(row.dataset.estado);

                const coincideBusqueda =
                    !query
                    || cliente.includes(query)
                    || tipo.includes(query)
                    || numero.includes(query);

                const coincideEstado =
                    estado === 'todos'
                    || estadoFila === estado;

                return coincideBusqueda
                    && coincideEstado;
            });

            currentPage = 1;

            render();
        }

        function render() {
            const total =
                filteredRows.length;

            const totalPages =
                Math.max(
                    1,
                    Math.ceil(total / PAGE_SIZE));

            currentPage =
                Math.min(currentPage, totalPages);

            const start =
                (currentPage - 1) * PAGE_SIZE;

            const end =
                start + PAGE_SIZE;

            allRows.forEach(row =>
                row.classList.add('d-none'));

            filteredRows
                .slice(start, end)
                .forEach(row =>
                    row.classList.remove('d-none'));

            emptyMsg.classList.toggle(
                'd-none',
                total > 0);

            paginationInfo.textContent =
                total > 0
                    ? `Mostrando ${Math.min(start + 1, total)}–${Math.min(end, total)} de ${total} contrato${total !== 1 ? 's' : ''}`
                    : '';

            pagination.innerHTML = '';

            if (totalPages <= 1) {
                return;
            }

            const ul =
                document.createElement('ul');

            ul.className =
                'pagination pagination-sm mb-0';

            const makeButton =
                (label, page, disabled, active) => {

                    const li =
                        document.createElement('li');

                    li.className =
                        `page-item ${disabled ? 'disabled' : ''} ${active ? 'active' : ''}`;

                    const anchor =
                        document.createElement('a');

                    anchor.className = 'page-link';
                    anchor.href = '#';
                    anchor.innerHTML = label;

                    if (active) {
                        anchor.style.background =
                            '#534AB7';

                        anchor.style.borderColor =
                            '#534AB7';
                    }

                    if (!disabled && !active) {
                        anchor.addEventListener(
                            'click',
                            event => {

                                event.preventDefault();

                                currentPage = page;

                                render();
                            });
                    }

                    li.appendChild(anchor);

                    return li;
                };

            ul.appendChild(
                makeButton(
                    '&laquo;',
                    currentPage - 1,
                    currentPage === 1,
                    false));

            const pages = [];

            if (currentPage > 3) {
                pages.push(1, '...');
            }

            for (
                let i = Math.max(1, currentPage - 2);
                i <= Math.min(
                    totalPages,
                    currentPage + 2);
                i++
            ) {
                pages.push(i);
            }

            if (currentPage < totalPages - 2) {
                pages.push('...', totalPages);
            }

            pages.forEach(page => {
                if (page === '...') {
                    const li =
                        document.createElement('li');

                    li.className =
                        'page-item disabled';

                    li.innerHTML =
                        '<span class="page-link">…</span>';

                    ul.appendChild(li);
                }
                else {
                    ul.appendChild(
                        makeButton(
                            page,
                            page,
                            false,
                            page === currentPage));
                }
            });

            ul.appendChild(
                makeButton(
                    '&raquo;',
                    currentPage + 1,
                    currentPage === totalPages,
                    false));

            pagination.appendChild(ul);
        }

        searchInput.addEventListener(
            'input',
            filter);

        statusFilter.addEventListener(
            'change',
            filter);

        filter();
    </script>
}