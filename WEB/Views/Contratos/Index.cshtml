@model IEnumerable<WEB.Models.ViewModels.ContratoViewModel>

@{
    ViewData["Title"] = "Contratos";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Contratos</h2>
            <p class="text-muted mb-0">
                Administración de contratos generados.
            </p>
        </div>

        <a asp-action="Crear"
           class="btn btn-primary">
            <i class="bi bi-plus-circle"></i>
            Nuevo contrato
        </a>
    </div>

    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Exito"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert">
            </button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert">
            </button>
        </div>
    }

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger">
            @ViewBag.Error
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body">

            @if (Model == null || !Model.Any())
            {
                <div class="text-center py-5">
                    <i class="bi bi-file-earmark-text fs-1 text-muted"></i>

                    <h5 class="mt-3">
                        No hay contratos registrados
                    </h5>

                    <p class="text-muted">
                        Puedes crear un contrato desde una cotización aprobada.
                    </p>
                </div>
            }
            else
            {
                <div class="table-responsive">

                    <table class="table table-hover align-middle">

                        <thead class="table-light">
                            <tr>
                                <th>Número</th>
                                <th>Cliente</th>
                                <th>Evento</th>
                                <th>Fecha del evento</th>
                                <th>Total</th>
                                <th>Estado</th>
                                <th>Fecha contrato</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>

                        <tbody>

                            @foreach (var contrato in Model)
                            {
                                <tr>
                                    <td>
                                        <strong>
                                            @contrato.NumeroContrato
                                        </strong>
                                    </td>

                                    <td>
                                        @contrato.ClienteNombre
                                    </td>

                                    <td>
                                        @contrato.TipoEvento
                                    </td>

                                    <td>
                                        @if (contrato.FechaEvento != DateTime.MinValue)
                                        {
                                            @contrato.FechaEvento.ToString("dd/MM/yyyy")
                                        }
                                        else
                                        {
                                            <span class="text-muted">
                                                Sin fecha
                                            </span>
                                        }
                                    </td>

                                    <td>
                                        ₡@contrato.Total.ToString("N2")
                                    </td>

                                    <td>
                                        @{
                                            var claseEstado =
                                                contrato.Estado switch
                                                {
                                                    "Pendiente" => "bg-warning text-dark",
                                                    "Firmado" => "bg-success",
                                                    "Cancelado" => "bg-danger",
                                                    "Anulado" => "bg-secondary",
                                                    _ => "bg-info text-dark"
                                                };
                                        }

                                        <span class="badge @claseEstado">
                                            @contrato.Estado
                                        </span>
                                    </td>

                                    <td>
                                        @contrato.FechaContrato.ToString("dd/MM/yyyy")
                                    </td>

                                    <td class="text-center">

                                        <div class="btn-group btn-group-sm">

                                            <a asp-action="Detalles"
                                               asp-route-id="@contrato.ContratoId"
                                               class="btn btn-outline-secondary"
                                               title="Ver detalles">

                                                <i class="bi bi-eye"></i>

                                            </a>

                                            <a asp-action="Editar"
                                               asp-route-id="@contrato.ContratoId"
                                               class="btn btn-outline-primary"
                                               title="Editar">

                                                <i class="bi bi-pencil-square"></i>

                                            </a>

                                            <a asp-action="DescargarPdf"
                                               asp-route-id="@contrato.ContratoId"
                                               class="btn btn-outline-danger"
                                               title="Descargar PDF"
                                               target="_blank">

                                                <i class="bi bi-file-earmark-pdf"></i>

                                            </a>

                                            <form asp-action="Enviar"
                                                  asp-route-id="@contrato.ContratoId"
                                                  method="post"
                                                  class="d-inline">

                                                @Html.AntiForgeryToken()

                                                <button type="submit"
                                                        class="btn btn-outline-success"
                                                        title="Enviar por correo"
                                                        onclick="return confirm('¿Desea enviar este contrato al cliente?');">

                                                    <i class="bi bi-envelope"></i>

                                                </button>

                                            </form>

                                        </div>

                                    </td>
                                </tr>
                            }

                        </tbody>

                    </table>

                </div>
            }

        </div>
    </div>
</div>