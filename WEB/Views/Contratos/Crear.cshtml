@model WEB.Models.ViewModels.ContratoFormViewModel

@{
    ViewData["Title"] = "Crear contrato";
}

<div class="container mt-4">

    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="card shadow-sm border-0">

                <div class="card-header bg-white py-3">
                    <h4 class="mb-1">
                        Crear contrato
                    </h4>

                    <p class="text-muted mb-0">
                        Selecciona una cotización aprobada.
                    </p>
                </div>

                <div class="card-body p-4">

                    @if (ViewBag.ErrorCotizaciones != null)
                    {
                        <div class="alert alert-danger">
                            @ViewBag.ErrorCotizaciones
                        </div>
                    }

                    <form asp-action="Crear"
                          method="post">

                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly"
                             class="alert alert-danger">
                        </div>

                        <div class="mb-3">

                            <label asp-for="CotizacionId"
                                   class="form-label">
                                Cotización
                            </label>

                            <select asp-for="CotizacionId"
                                    class="form-select">

                                <option value="">
                                    Seleccione una cotización
                                </option>

                                @foreach (var cotizacion in Model.Cotizaciones)
                                {
                                    <option value="@cotizacion.CotizacionId">
                                        @cotizacion.TextoOpcion
                                    </option>
                                }

                            </select>

                            <span asp-validation-for="CotizacionId"
                                  class="text-danger">
                            </span>

                            @if (Model.Cotizaciones.Count == 0)
                            {
                                <small class="text-muted d-block mt-2">
                                    No existen cotizaciones aprobadas disponibles.
                                </small>
                            }

                        </div>

                        <div class="mb-3">

                            <label asp-for="Observaciones"
                                   class="form-label">
                                Observaciones
                            </label>

                            <textarea asp-for="Observaciones"
                                      class="form-control"
                                      rows="5"
                                      placeholder="Escriba observaciones adicionales para el contrato"></textarea>

                            <span asp-validation-for="Observaciones"
                                  class="text-danger">
                            </span>

                        </div>

                        <div class="alert alert-info">

                            <i class="bi bi-info-circle"></i>

                            El número del contrato y la fecha de creación
                            se generarán automáticamente.

                        </div>

                        <div class="d-flex justify-content-end gap-2">

                            <a asp-action="Index"
                               class="btn btn-outline-secondary">

                                Cancelar

                            </a>

                            <button type="submit"
                                    class="btn btn-primary"
                                @(Model.Cotizaciones.Count == 0 ? "disabled" : null)>

                                <i class="bi bi-save"></i>
                                Crear contrato

                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}