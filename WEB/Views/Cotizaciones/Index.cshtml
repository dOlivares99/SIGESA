@model List<WEB.Models.ViewModels.CotizacionViewModel>
@{
    ViewData["Title"] = "Cotizaciones";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="fw-bold mb-0">Cotizaciones</h5>
        <small class="text-muted">Gestiona las cotizaciones generadas para cada evento</small>
    </div>
    <a asp-action="Crear" class="btn btn-primary btn-sm px-3">
        <i class="ti ti-plus me-1"></i> Nueva cotización
    </a>
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success"><i class="ti ti-circle-check me-1"></i>@TempData["Exito"]</div>
}
@if (ViewBag.Error != null)
{
    <div class="alert alert-danger"><i class="ti ti-alert-circle me-1"></i>@ViewBag.Error</div>
}

<div class="card">
    <div class="card-body">

        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
            <div class="d-flex gap-2">
                <input type="text" id="searchInput" class="form-control form-control-sm"
                       placeholder="Buscar por cliente o tipo de evento..."
                       style="min-width:260px;">
                <select id="statusFilter" class="form-select form-select-sm" style="min-width:160px;">
                    <option value="todos">Todos los estados</option>
                    <option value="pendiente">Pendiente</option>
                    <option value="aprobada">Aprobada</option>
                    <option value="rechazada">Rechazada</option>
                    <option value="vencida">Vencida</option>
                </select>
            </div>
            <small class="text-muted" id="paginationInfo"></small>
        </div>

        <table class="table table-hover align-middle mb-0" id="mainTable">
            <thead style="background:#f8f7ff;">
                <tr>
                    <th class="ps-3 py-3" style="color:#534AB7;">#</th>
                    <th class="py-3" style="color:#534AB7;">Cliente</th>
                    <th class="py-3" style="color:#534AB7;">Tipo de evento</th>
                    <th class="py-3" style="color:#534AB7;">Total</th>
                    <th class="py-3" style="color:#534AB7;">Estado</th>
                    <th class="py-3" style="color:#534AB7;">Creación</th>
                    <th class="py-3" style="color:#534AB7;">Vencimiento</th>
                    <th class="py-3" style="color:#534AB7;">Acciones</th>
                </tr>
            </thead>
            <tbody id="tableBody">
                @foreach (var c in Model)
                {
                    var estadoKey = c.Estado.ToLower();
                    var (estadoBg, estadoColor) = estadoKey switch {
                        "aprobada"  => ("#e6f4f0", "#0F6E56"),
                        "rechazada" => ("#ffeee8", "#993C1D"),
                        "vencida"   => ("#f5f5f5", "#555555"),
                        _           => ("#fff8e6", "#854F0B")
                    };

                    <tr data-cliente="@c.ClienteNombre.ToLower()"
                        data-tipo="@c.TipoEvento.ToLower()"
                        data-estado="@c.Estado.ToLower()">
                        <td class="ps-3">@c.CotizacionId</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold"
                                     style="width:32px;height:32px;background:#f0eeff;color:#534AB7;font-size:0.8rem;">
                                    @c.ClienteNombre.Substring(0, 1).ToUpper()
                                </div>
                                <span class="fw-medium">@c.ClienteNombre</span>
                            </div>
                        </td>
                        <td class="text-muted small">@c.TipoEvento</td>
                        <td class="fw-medium">₡@c.Total.ToString("N2")</td>
                        <td>
                            <span class="badge rounded-pill px-3"
                                  style="background:@estadoBg;color:@estadoColor;">
                                @c.Estado
                            </span>
                        </td>
                        <td class="text-muted small">@c.FechaCreacion.ToString("dd/MM/yyyy")</td>
                        <td class="text-muted small">
                            @(c.FechaVencimiento.HasValue ? c.FechaVencimiento.Value.ToString("dd/MM/yyyy") : "—")
                        </td>
                        <td>
                            <a asp-action="Detalle" asp-route-id="@c.CotizacionId"
                               class="btn btn-sm btn-outline-secondary" title="Ver detalle">
                                <i class="ti ti-eye"></i>
                            </a>
                            <a asp-action="Editar" asp-route-id="@c.CotizacionId"
                               class="btn btn-sm btn-outline-secondary" title="Editar">
                                <i class="ti ti-edit"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div id="emptyMsg" class="text-center text-muted py-5 d-none">
            <i class="ti ti-search-off" style="font-size:2rem;"></i>
            <p class="mt-2 mb-0">No se encontraron resultados</p>
        </div>

        <div class="d-flex justify-content-center mt-3" id="pagination"></div>

    </div>
</div>

@section Scripts {
<script>
    const PAGE_SIZE = 10;
    let currentPage = 1;
    let filteredRows = [];

    const searchInput    = document.getElementById('searchInput');
    const statusFilter   = document.getElementById('statusFilter');
    const tableBody      = document.getElementById('tableBody');
    const allRows        = Array.from(tableBody.querySelectorAll('tr'));
    const pagination     = document.getElementById('pagination');
    const paginationInfo = document.getElementById('paginationInfo');
    const emptyMsg       = document.getElementById('emptyMsg');

    function normalize(str) {
        return str.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '');
    }

    function filter() {
        const q      = normalize(searchInput.value.trim());
        const estado = statusFilter.value;

        filteredRows = allRows.filter(r => {
            const matchSearch = !q ||
                normalize(r.dataset.cliente).includes(q) ||
                normalize(r.dataset.tipo).includes(q);
            const matchEstado = estado === 'todos' || r.dataset.estado === estado;
            return matchSearch && matchEstado;
        });

        currentPage = 1;
        render();
    }

    function render() {
        const total      = filteredRows.length;
        const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
        currentPage      = Math.min(currentPage, totalPages);
        const start      = (currentPage - 1) * PAGE_SIZE;
        const end        = start + PAGE_SIZE;

        allRows.forEach(r => r.classList.add('d-none'));
        filteredRows.slice(start, end).forEach(r => r.classList.remove('d-none'));

        emptyMsg.classList.toggle('d-none', total > 0);

        paginationInfo.textContent = total > 0
            ? `Mostrando ${Math.min(start + 1, total)}–${Math.min(end, total)} de ${total} cotización${total !== 1 ? 'es' : ''}`
            : '';

        pagination.innerHTML = '';
        if (totalPages <= 1) return;

        const ul = document.createElement('ul');
        ul.className = 'pagination pagination-sm mb-0';

        const makeBtn = (label, page, disabled, active) => {
            const li = document.createElement('li');
            li.className = `page-item ${disabled ? 'disabled' : ''} ${active ? 'active' : ''}`;
            const a = document.createElement('a');
            a.className = 'page-link';
            a.href = '#';
            a.innerHTML = label;
            if (active) {
                a.style.background = '#534AB7';
                a.style.borderColor = '#534AB7';
            }
            if (!disabled && !active) {
                a.addEventListener('click', e => {
                    e.preventDefault();
                    currentPage = page;
                    render();
                });
            }
            li.appendChild(a);
            return li;
        };

        ul.appendChild(makeBtn('&laquo;', currentPage - 1, currentPage === 1, false));

        const showPages = [];
        if (currentPage > 3) showPages.push(1, '...');
        for (let i = Math.max(1, currentPage - 2); i <= Math.min(totalPages, currentPage + 2); i++) {
            showPages.push(i);
        }
        if (currentPage < totalPages - 2) showPages.push('...', totalPages);

        showPages.forEach(p => {
            if (p === '...') {
                const li = document.createElement('li');
                li.className = 'page-item disabled';
                li.innerHTML = '<a class="page-link">…</a>';
                ul.appendChild(li);
            } else {
                ul.appendChild(makeBtn(p, p, false, p === currentPage));
            }
        });

        ul.appendChild(makeBtn('&raquo;', currentPage + 1, currentPage === totalPages, false));
        pagination.appendChild(ul);
    }

    searchInput.addEventListener('input', filter);
    statusFilter.addEventListener('change', filter);
    filter();
</script>
}
