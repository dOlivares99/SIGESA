@model List<WEB.Models.ViewModels.CotizacionViewModel>

@{
    ViewData["Title"] = "Cotizaciones";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="fw-bold mb-0">Cotizaciones</h5>
        <small class="text-muted">
            Gestiona las cotizaciones generadas para cada evento
        </small>
    </div>

    <a asp-action="Crear"
       class="btn btn-primary btn-sm px-3">
        <i class="ti ti-plus me-1"></i>
        Nueva cotización
    </a>
</div>

@if (TempData["Exito"] != null)
{
    <div class="alert alert-success alert-dismissible fade show"
         role="alert">
        <i class="ti ti-circle-check me-1"></i>
        @TempData["Exito"]

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert"
                aria-label="Cerrar">
        </button>
    </div>
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show"
         role="alert">
        <i class="ti ti-alert-circle me-1"></i>
        @TempData["Error"]

        <button type="button"
                class="btn-close"
                data-bs-dismiss="alert"
                aria-label="Cerrar">
        </button>
    </div>
}

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger"
         role="alert">
        <i class="ti ti-alert-circle me-1"></i>
        @ViewBag.Error
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="card-body">

        <div class="d-flex flex-wrap justify-content-between align-items-center gap-2 mb-3">
            <div class="d-flex flex-wrap gap-2">

                <input type="text"
                       id="searchInput"
                       class="form-control form-control-sm"
                       placeholder="Buscar por cliente o tipo de evento..."
                       style="min-width:260px;" />

                <select id="statusFilter"
                        class="form-select form-select-sm"
                        style="min-width:170px;">

                    <option value="todos">Todos los estados</option>
                    <option value="borrador">Borrador</option>
                    <option value="enviada">Enviada</option>
                    <option value="aprobada">Aprobada</option>
                    <option value="rechazada">Rechazada</option>
                    <option value="vencida">Vencida</option>
                </select>
            </div>

            <small class="text-muted"
                   id="paginationInfo">
            </small>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0"
                   id="mainTable">

                <thead style="background:#f8f7ff;">
                    <tr>
                        <th class="ps-3 py-3"
                            style="color:#534AB7;">
                            #
                        </th>

                        <th class="py-3"
                            style="color:#534AB7;">
                            Cliente
                        </th>

                        <th class="py-3"
                            style="color:#534AB7;">
                            Tipo de evento
                        </th>

                        <th class="py-3"
                            style="color:#534AB7;">
                            Total
                        </th>

                        <th class="py-3"
                            style="color:#534AB7;">
                            Estado
                        </th>

                        <th class="py-3"
                            style="color:#534AB7;">
                            Creación
                        </th>

                        <th class="py-3"
                            style="color:#534AB7;">
                            Vencimiento
                        </th>

                        <th class="py-3 text-center"
                            style="color:#534AB7;">
                            Acciones
                        </th>
                    </tr>
                </thead>

                <tbody id="tableBody">

                    @foreach (var c in Model)
                    {
                        var estadoKey =
                            (c.Estado ?? "").Trim().ToLowerInvariant();

                        var estadoBg = "#fff8e6";
                        var estadoColor = "#854F0B";

                        switch (estadoKey)
                        {
                            case "enviada":
                                estadoBg = "#ece9ff";
                                estadoColor = "#534AB7";
                                break;

                            case "aprobada":
                            case "aceptada":
                                estadoBg = "#e6f4f0";
                                estadoColor = "#0F6E56";
                                break;

                            case "rechazada":
                                estadoBg = "#ffeee8";
                                estadoColor = "#993C1D";
                                break;

                            case "vencida":
                                estadoBg = "#f0f0f0";
                                estadoColor = "#555555";
                                break;

                            case "borrador":
                                estadoBg = "#fff8e6";
                                estadoColor = "#854F0B";
                                break;
                        }

                        var clienteNombre =
                            string.IsNullOrWhiteSpace(c.ClienteNombre)
                                ? "Sin cliente"
                                : c.ClienteNombre;

                        var tipoEvento =
                            string.IsNullOrWhiteSpace(c.TipoEvento)
                                ? "Sin tipo"
                                : c.TipoEvento;

                        var inicialCliente =
                            clienteNombre.Length > 0
                                ? clienteNombre.Substring(0, 1).ToUpper()
                                : "?";

                        var puedeEnviar =
                            estadoKey != "aprobada"
                            && estadoKey != "aceptada"
                            && estadoKey != "rechazada"
                            && estadoKey != "vencida";

                        <tr data-cliente="@clienteNombre.ToLowerInvariant()"
                            data-tipo="@tipoEvento.ToLowerInvariant()"
                            data-estado="@estadoKey">

                            <td class="ps-3">
                                @c.CotizacionId
                            </td>

                            <td>
                                <div class="d-flex align-items-center gap-2">

                                    <div class="rounded-circle d-flex align-items-center justify-content-center fw-bold"
                                         style="width:32px;
                                        height:32px;
                                        min-width:32px;
                                        background:#f0eeff;
                                        color:#534AB7;
                                        font-size:0.8rem;">
                                        @inicialCliente
                                    </div>

                                    <span class="fw-medium">
                                        @clienteNombre
                                    </span>
                                </div>
                            </td>

                            <td class="text-muted small">
                                @tipoEvento
                            </td>

                            <td class="fw-medium">
                                ₡@c.Total.ToString("N2")
                            </td>

                            <td>
                                <span class="badge rounded-pill px-3"
                                      style="background:@estadoBg;
                                    color:@estadoColor;">
                                    @c.Estado
                                </span>
                            </td>

                            <td class="text-muted small">
                                @c.FechaCreacion.ToString("dd/MM/yyyy")
                            </td>

                            <td class="text-muted small">
                                @(c.FechaVencimiento.HasValue
                                    ? c.FechaVencimiento.Value.ToString("dd/MM/yyyy")
                                    : "—")
                            </td>

                            <td>
                                <div class="d-flex justify-content-center flex-wrap gap-1">

                                    <a asp-action="Editar"
                                       asp-route-id="@c.CotizacionId"
                                       class="btn btn-sm btn-outline-secondary"
                                       title="Editar cotización">
                                        <i class="ti ti-edit"></i>
                                    </a>

                                    <a asp-action="DescargarPdf"
                                       asp-route-id="@c.CotizacionId"
                                       class="btn btn-sm btn-outline-primary"
                                       title="Descargar PDF"
                                       target="_blank">
                                        <i class="ti ti-file-type-pdf"></i>
                                    </a>

                                    @if (puedeEnviar)
                                    {
                                        <button type="button"
                                                class="btn btn-sm btn-outline-success"
                                                title="Enviar cotización por correo"
                                                data-bs-toggle="modal"
                                                data-bs-target="#modalEnviarCotizacion"
                                                data-id="@c.CotizacionId"
                                                data-cliente="@clienteNombre">
                                            <i class="ti ti-mail-forward"></i>
                                        </button>
                                    }
                                    else
                                    {
                                        <button type="button"
                                                class="btn btn-sm btn-outline-secondary"
                                                title="Esta cotización ya no se puede enviar"
                                                disabled>
                                            <i class="ti ti-mail-off"></i>
                                        </button>
                                    }
                                    @if (estadoKey == "aprobada"
    || estadoKey == "aceptada")
                                    {
                                        if (!c.TieneContrato)
                                        {
                                            <a asp-controller="Contratos"
                                               asp-action="Crear"
                                               asp-route-cotizacionId="@c.CotizacionId"
                                               class="btn btn-sm btn-outline-warning"
                                               title="Generar contrato">

                                                <i class="ti ti-file-description"></i>
                                            </a>
                                        }
                                        else if (c.ContratoId.HasValue)
                                        {
                                            <a asp-controller="Contratos"
                                               asp-action="Detalles"
                                               asp-route-id="@c.ContratoId.Value"
                                               class="btn btn-sm btn-outline-dark"
                                               title="Ver contrato">

                                                <i class="ti ti-eye"></i>
                                            </a>
                                        }
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div id="emptyMsg"
             class="text-center text-muted py-5 d-none">

            <i class="ti ti-search-off"
               style="font-size:2rem;">
            </i>

            <p class="mt-2 mb-0">
                No se encontraron resultados
            </p>
        </div>

        <div class="d-flex justify-content-center mt-3"
             id="pagination">
        </div>
    </div>
</div>

<div class="modal fade"
     id="modalEnviarCotizacion"
     tabindex="-1"
     aria-labelledby="modalEnviarCotizacionLabel"
     aria-hidden="true">

    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">

            <div class="modal-header"
                 style="background:#f8f7ff;">

                <h5 class="modal-title fw-bold"
                    id="modalEnviarCotizacionLabel"
                    style="color:#534AB7;">

                    <i class="ti ti-mail-forward me-1"></i>
                    Enviar cotización
                </h5>

                <button type="button"
                        class="btn-close"
                        data-bs-dismiss="modal"
                        aria-label="Cerrar">
                </button>
            </div>

            <div class="modal-body">
                <p class="mb-2">
                    Se enviará la cotización
                    <strong id="numeroCotizacionModal"></strong>
                    al correo registrado del cliente:
                </p>

                <p class="fw-bold mb-0"
                   id="clienteCotizacionModal"
                   style="color:#534AB7;">
                </p>

                <div class="alert alert-light border mt-3 mb-0">
                    <i class="ti ti-file-type-pdf me-1"></i>
                    El correo incluirá el PDF de la cotización como archivo adjunto.
                </div>
            </div>

            <div class="modal-footer">
                <button type="button"
                        class="btn btn-outline-secondary"
                        data-bs-dismiss="modal">
                    Cancelar
                </button>

                <form asp-action="Enviar"
                      method="post"
                      id="formEnviarCotizacion">

                    @Html.AntiForgeryToken()

                    <input type="hidden"
                           name="id"
                           id="cotizacionIdEnviar" />

                    <button type="submit"
                            class="btn btn-primary"
                            id="btnConfirmarEnvio">

                        <i class="ti ti-send me-1"></i>
                        Enviar cotización
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <script>
        const PAGE_SIZE = 10;

        let currentPage = 1;
        let filteredRows = [];

        const searchInput =
            document.getElementById('searchInput');

        const statusFilter =
            document.getElementById('statusFilter');

        const tableBody =
            document.getElementById('tableBody');

        const allRows =
            Array.from(tableBody.querySelectorAll('tr'));

        const pagination =
            document.getElementById('pagination');

        const paginationInfo =
            document.getElementById('paginationInfo');

        const emptyMsg =
            document.getElementById('emptyMsg');

        function normalize(value) {
            return (value || '')
                .toLowerCase()
                .normalize('NFD')
                .replace(/[\u0300-\u036f]/g, '');
        }

        function filter() {
            const query =
                normalize(searchInput.value.trim());

            const estado =
                statusFilter.value;

            filteredRows = allRows.filter(row => {
                const cliente =
                    normalize(row.dataset.cliente);

                const tipo =
                    normalize(row.dataset.tipo);

                const estadoFila =
                    normalize(row.dataset.estado);

                const coincideBusqueda =
                    !query
                    || cliente.includes(query)
                    || tipo.includes(query);

                const coincideEstado =
                    estado === 'todos'
                    || estadoFila === normalize(estado);

                return coincideBusqueda && coincideEstado;
            });

            currentPage = 1;

            render();
        }

        function render() {
            const total =
                filteredRows.length;

            const totalPages =
                Math.max(1, Math.ceil(total / PAGE_SIZE));

            currentPage =
                Math.min(currentPage, totalPages);

            const start =
                (currentPage - 1) * PAGE_SIZE;

            const end =
                start + PAGE_SIZE;

            allRows.forEach(row =>
                row.classList.add('d-none'));

            filteredRows
                .slice(start, end)
                .forEach(row =>
                    row.classList.remove('d-none'));

            emptyMsg.classList.toggle(
                'd-none',
                total > 0);

            paginationInfo.textContent =
                total > 0
                    ? `Mostrando ${Math.min(start + 1, total)}–${Math.min(end, total)} de ${total} cotización${total !== 1 ? 'es' : ''}`
                    : '';

            pagination.innerHTML = '';

            if (totalPages <= 1) {
                return;
            }

            const ul =
                document.createElement('ul');

            ul.className =
                'pagination pagination-sm mb-0';

            const makeButton =
                (label, page, disabled, active) => {

                    const li =
                        document.createElement('li');

                    li.className =
                        `page-item ${disabled ? 'disabled' : ''} ${active ? 'active' : ''}`;

                    const anchor =
                        document.createElement('a');

                    anchor.className =
                        'page-link';

                    anchor.href = '#';

                    anchor.innerHTML = label;

                    if (active) {
                        anchor.style.background = '#534AB7';
                        anchor.style.borderColor = '#534AB7';
                    }

                    if (!disabled && !active) {
                        anchor.addEventListener(
                            'click',
                            event => {

                                event.preventDefault();

                                currentPage = page;

                                render();
                            });
                    }

                    li.appendChild(anchor);

                    return li;
                };

            ul.appendChild(
                makeButton(
                    '&laquo;',
                    currentPage - 1,
                    currentPage === 1,
                    false));

            const pages = [];

            if (currentPage > 3) {
                pages.push(1, '...');
            }

            for (
                let i = Math.max(1, currentPage - 2);
                i <= Math.min(totalPages, currentPage + 2);
                i++
            ) {
                pages.push(i);
            }

            if (currentPage < totalPages - 2) {
                pages.push('...', totalPages);
            }

            pages.forEach(page => {
                if (page === '...') {
                    const li =
                        document.createElement('li');

                    li.className =
                        'page-item disabled';

                    li.innerHTML =
                        '<span class="page-link">…</span>';

                    ul.appendChild(li);
                }
                else {
                    ul.appendChild(
                        makeButton(
                            page,
                            page,
                            false,
                            page === currentPage));
                }
            });

            ul.appendChild(
                makeButton(
                    '&raquo;',
                    currentPage + 1,
                    currentPage === totalPages,
                    false));

            pagination.appendChild(ul);
        }

        searchInput.addEventListener(
            'input',
            filter);

        statusFilter.addEventListener(
            'change',
            filter);

        const modalEnviar =
            document.getElementById(
                'modalEnviarCotizacion');

        modalEnviar.addEventListener(
            'show.bs.modal',
            event => {

                const boton =
                    event.relatedTarget;

                const id =
                    boton.getAttribute('data-id');

                const cliente =
                    boton.getAttribute('data-cliente');

                document.getElementById(
                    'cotizacionIdEnviar').value = id;

                document.getElementById(
                    'numeroCotizacionModal').textContent =
                    `#${id}`;

                document.getElementById(
                    'clienteCotizacionModal').textContent =
                    cliente;
            });

        const formEnviar =
            document.getElementById(
                'formEnviarCotizacion');

        formEnviar.addEventListener(
            'submit',
            () => {

                const boton =
                    document.getElementById(
                        'btnConfirmarEnvio');

                boton.disabled = true;

                boton.innerHTML =
                    '<span class="spinner-border spinner-border-sm me-1"></span> Enviando...';
            });

        filter();
    </script>
}
