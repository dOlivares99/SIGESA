@model WEB.Models.ViewModels.CotizacionFormViewModel
@{
    ViewData["Title"] = "Nueva cotización";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="ti ti-arrow-left"></i>
    </a>
    <div>
        <h5 class="fw-bold mb-0">Nueva cotización</h5>
        <small class="text-muted">Genera una cotización para un evento</small>
    </div>
</div>

<div class="row g-4">

    <div class="col-12 col-lg-7">
        <div class="card h-100">
            <div class="card-body p-4">

                @if (ViewBag.ErrorReservas != null)
                {
                    <div class="alert alert-danger py-2">
                        <i class="ti ti-alert-circle me-1"></i> @ViewBag.ErrorReservas
                    </div>
                }

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger py-2">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div><i class="ti ti-alert-circle me-1"></i>@error.ErrorMessage</div>
                        }
                    </div>
                }

                <form asp-action="Crear" method="post">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="EventoId" class="form-label fw-medium">Reserva</label>
                        <select asp-for="EventoId" class="form-select" id="selectEvento">
                            <option value="">— Selecciona una reserva —</option>
                            @foreach (var r in Model.Reservas)
                            {
                                <option value="@r.EventoId"
                                        data-monto="@r.MontoTotal.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)"
                                        data-cliente="@r.ClienteNombre"
                                        data-tipo="@r.TipoEvento"
                                        data-fecha="@r.FechaEvento.ToString("dd/MM/yyyy")">
                                    @r.ClienteNombre — @r.TipoEvento (@r.FechaEvento.ToString("dd/MM/yyyy"))
                                </option>
                            }
                        </select>
                        <span asp-validation-for="EventoId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Total" class="form-label fw-medium">Total (₡)</label>
                        <input asp-for="Total" type="number" step="0.01" min="0"
                               class="form-control" placeholder="Se completa al seleccionar reserva"
                               id="inputTotal" />
                        <div class="form-text">
                            Se completa automáticamente con el monto de la reserva.
                            Puedes ajustarlo si es necesario.
                        </div>
                        <span asp-validation-for="Total" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="FechaVencimiento" class="form-label fw-medium">
                            Fecha de vencimiento
                            <span class="text-muted fw-normal">(opcional)</span>
                        </label>
                        <input asp-for="FechaVencimiento" type="date" class="form-control"
                               id="inputFechaVenc" />
                        <div class="form-text">
                            Por defecto se sugieren 15 días desde hoy.
                        </div>
                        <span asp-validation-for="FechaVencimiento" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="ti ti-device-floppy me-1"></i> Guardar
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>

            </div>
        </div>
    </div>

    <div class="col-12 col-lg-5">
        <div class="card h-100" style="background:#f8f7ff;border:1.5px solid #ece9ff;">
            <div class="card-body p-4">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center"
                         style="width:40px;height:40px;background:#534AB7;">
                        <i class="ti ti-file-invoice text-white"></i>
                    </div>
                    <div>
                        <div class="fw-semibold" style="color:#534AB7;">Vista previa</div>
                        <small class="text-muted">Datos de la reserva seleccionada</small>
                    </div>
                </div>
                <hr style="border-color:#ece9ff;">

                <!-- Estado vacío -->
                <div id="previewVacio" class="text-center py-4">
                    <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto mb-3"
                         style="width:56px;height:56px;background:#ece9ff;">
                        <i class="ti ti-file-search" style="font-size:1.5rem;color:#534AB7;"></i>
                    </div>
                    <p class="text-muted small mb-0">
                        Selecciona una reserva para ver<br>el resumen aquí
                    </p>
                </div>

                <!-- Datos de la reserva seleccionada -->
                <div id="previewDatos" class="d-none">
                    <div class="mb-3">
                        <small class="text-muted d-block mb-1">Cliente</small>
                        <span class="fw-medium" id="prevCliente">—</span>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block mb-1">Tipo de evento</small>
                        <span class="fw-medium" id="prevTipo">—</span>
                    </div>
                    <div class="mb-3">
                        <small class="text-muted d-block mb-1">Fecha del evento</small>
                        <span class="fw-medium" id="prevFecha">—</span>
                    </div>
                    <hr style="border-color:#ece9ff;">
                    <div class="mb-1">
                        <small class="text-muted d-block mb-1">Monto base</small>
                        <span class="fw-bold fs-5" style="color:#534AB7;" id="prevMonto">₡0.00</span>
                    </div>
                    <small class="text-muted">
                        Este valor se cargó automáticamente en el campo Total.
                        Puedes ajustarlo si el acuerdo con el cliente es diferente.
                    </small>
                </div>

                <hr style="border-color:#ece9ff;">
                <div class="d-flex align-items-start gap-2 mt-3">
                    <i class="ti ti-info-circle mt-1" style="color:#534AB7;"></i>
                    <small class="text-muted">
                        La cotización se creará en estado <strong>Borrador</strong>.
                        Podrás cambiar su estado desde el listado.
                    </small>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        const select       = document.getElementById('selectEvento');
        const inputTotal   = document.getElementById('inputTotal');
        const inputFechaV  = document.getElementById('inputFechaVenc');
        const previewVacio = document.getElementById('previewVacio');
        const previewDatos = document.getElementById('previewDatos');

        // Fecha default: hoy + 15 días
        const hoy = new Date();
        hoy.setDate(hoy.getDate() + 15);
        inputFechaV.value = hoy.toISOString().split('T')[0];

        select.addEventListener('change', () => {
            const opt = select.options[select.selectedIndex];

            if (!select.value) {
                previewVacio.classList.remove('d-none');
                previewDatos.classList.add('d-none');
                inputTotal.value = '';
                return;
            }

            const monto = parseFloat(opt.dataset.monto);

            // Auto-rellenar Total
            inputTotal.value = monto.toFixed(2);

            // Actualizar vista previa
            document.getElementById('prevCliente').textContent = opt.dataset.cliente;
            document.getElementById('prevTipo').textContent    = opt.dataset.tipo;
            document.getElementById('prevFecha').textContent   = opt.dataset.fecha;
            document.getElementById('prevMonto').textContent   =
                '₡' + monto.toLocaleString('es-CR', { minimumFractionDigits: 2 });

            previewVacio.classList.add('d-none');
            previewDatos.classList.remove('d-none');
        });
    </script>
}