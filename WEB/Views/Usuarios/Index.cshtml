@model List<WEB.Models.ViewModels.UsuarioViewModel>
@{
    ViewData["Title"] = "Usuarios";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h5 class="fw-bold mb-0">Usuarios</h5>
        <small class="text-muted">Administra los usuarios con acceso al sistema</small>
    </div>
    <a asp-action="Crear" class="btn btn-primary btn-sm px-3">
        <i class="ti ti-plus me-1"></i> Nuevo usuario
    </a>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger"><i class="ti ti-alert-circle me-1"></i>@ViewBag.Error</div>
}

<div class="card">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <input type="text" id="searchInput" class="form-control form-control-sm"
                   placeholder="Buscar por nombre, correo o rol..."
                   style="max-width:300px;">
            <small class="text-muted" id="paginationInfo"></small>
        </div>

        <table class="table table-hover align-middle mb-0" id="mainTable">
            <thead style="background:#f8f7ff;">
                <tr>
                    <th class="ps-3 py-3" style="color:#534AB7;">#</th>
                    <th class="py-3" style="color:#534AB7;">Nombre</th>
                    <th class="py-3" style="color:#534AB7;">Correo</th>
                    <th class="py-3" style="color:#534AB7;">Rol</th>
                    <th class="py-3" style="color:#534AB7;">Estado</th>
                    <th class="py-3" style="color:#534AB7;">Acciones</th>
                </tr>
            </thead>
            <tbody id="tableBody">
                @foreach (var u in Model)
                {
                    <tr>
                        <td class="ps-3">@u.UsuarioId</td>
                        <td class="fw-medium">@u.Nombre</td>
                        <td class="text-muted small">@u.Email</td>
                        <td>
                            <span class="badge rounded-pill px-3"
                                  style="background:#f0eeff;color:#534AB7;">
                                @u.RolNombre
                            </span>
                        </td>
                        <td>
                            @if (u.Activo)
                            {
                                <span class="badge rounded-pill"
                                      style="background:#e6f4f0;color:#0F6E56;">
                                    <i class="ti ti-circle-check me-1"></i>Activo
                                </span>
                            }
                            else
                            {
                                <span class="badge rounded-pill bg-secondary">Inactivo</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Editar" asp-route-id="@u.UsuarioId"
                               class="btn btn-sm btn-outline-secondary" title="Editar">
                                <i class="ti ti-edit"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <div id="emptyMsg" class="text-center text-muted py-5 d-none">
            <i class="ti ti-search-off" style="font-size:2rem;"></i>
            <p class="mt-2 mb-0">No se encontraron resultados</p>
        </div>

        <div class="d-flex justify-content-center mt-3" id="pagination"></div>

    </div>
</div>

@section Scripts {
    <script>
        const PAGE_SIZE = 10;
        let currentPage = 1;
        let filteredRows = [];

        const searchInput    = document.getElementById('searchInput');
        const tableBody      = document.getElementById('tableBody');
        const allRows        = Array.from(tableBody.querySelectorAll('tr'));
        const pagination     = document.getElementById('pagination');
        const paginationInfo = document.getElementById('paginationInfo');
        const emptyMsg       = document.getElementById('emptyMsg');

        function normalize(str) {
            return str.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '');
        }

        function filter() {
            const q = normalize(searchInput.value.trim());
            filteredRows = q
                ? allRows.filter(r => normalize(r.innerText).includes(q))
                : [...allRows];
            currentPage = 1;
            render();
        }

        function render() {
            const total = filteredRows.length;
            const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
            currentPage = Math.min(currentPage, totalPages);
            const start = (currentPage - 1) * PAGE_SIZE;
            const end   = start + PAGE_SIZE;

            allRows.forEach(r => r.classList.add('d-none'));
            filteredRows.slice(start, end).forEach(r => r.classList.remove('d-none'));

            emptyMsg.classList.toggle('d-none', total > 0);

            paginationInfo.textContent = total > 0
                ? `Mostrando ${Math.min(start + 1, total)}–${Math.min(end, total)} de ${total}`
                : '';

            pagination.innerHTML = '';
            if (totalPages <= 1) return;

            const ul = document.createElement('ul');
            ul.className = 'pagination pagination-sm mb-0';

            const makeBtn = (label, page, disabled, active) => {
                const li = document.createElement('li');
                li.className = `page-item ${disabled ? 'disabled' : ''} ${active ? 'active' : ''}`;
                li.innerHTML = `<a class="page-link" href="#" style="${active ? 'background:#534AB7;border-color:#534AB7;' : ''}">${label}</a>`;
                if (!disabled && !active) {
                    li.querySelector('a').addEventListener('click', e => {
                        e.preventDefault();
                        currentPage = page;
                        render();
                    });
                }
                return li;
            };

            ul.appendChild(makeBtn('&laquo;', currentPage - 1, currentPage === 1, false));
            for (let i = 1; i <= totalPages; i++) {
                ul.appendChild(makeBtn(i, i, false, i === currentPage));
            }
            ul.appendChild(makeBtn('&raquo;', currentPage + 1, currentPage === totalPages, false));
            pagination.appendChild(ul);
        }

        searchInput.addEventListener('input', filter);
        filter();
    </script>
}