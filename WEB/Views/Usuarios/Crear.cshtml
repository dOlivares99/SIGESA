@model WEB.Models.ViewModels.CrearUsuarioViewModel
@{
    ViewData["Title"] = "Nuevo usuario";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="ti ti-arrow-left"></i>
    </a>
    <div>
        <h5 class="fw-bold mb-0">Nuevo usuario</h5>
        <small class="text-muted">Completa los datos del nuevo usuario</small>
    </div>
</div>

<div class="row g-4">

    <div class="col-12 col-lg-7">
        <div class="card h-100">
            <div class="card-body p-4">

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger py-2">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div><i class="ti ti-alert-circle me-1"></i>@error.ErrorMessage</div>
                        }
                    </div>
                }

                <form asp-action="Crear" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label fw-medium">Nombre completo</label>
                        <input asp-for="Nombre" class="form-control" placeholder="Ej: María García" />
                        <span asp-validation-for="Nombre" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-medium">Correo electrónico</label>
                        <input asp-for="Email" class="form-control" placeholder="correo@ejemplo.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-medium">Contraseña</label>
                        <input asp-for="Password" type="password" class="form-control"
                               placeholder="Mínimo 8 caracteres" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="RolId" class="form-label fw-medium">Rol</label>
                        <select asp-for="RolId" class="form-select">
                            <option value="">-- Seleccione un rol --</option>
                            <option value="1">Administrador</option>
                            <option value="2">Asistente</option>
                        </select>
                        <span asp-validation-for="RolId" class="text-danger small"></span>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="ti ti-device-floppy me-1"></i> Guardar
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>

            </div>
        </div>
    </div>

    <div class="col-12 col-lg-5">
        <div class="card h-100" style="background:#f8f7ff;border:1.5px solid #ece9ff;">
            <div class="card-body p-4">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center"
                         style="width:40px;height:40px;background:#534AB7;">
                        <i class="ti ti-user-plus text-white"></i>
                    </div>
                    <div>
                        <div class="fw-semibold" style="color:#534AB7;">Roles disponibles</div>
                        <small class="text-muted">Permisos por rol</small>
                    </div>
                </div>
                <hr style="border-color:#ece9ff;">
                <div class="mb-3">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <span class="badge rounded-pill px-3"
                              style="background:#534AB7;color:white;">Administrador</span>
                    </div>
                    <small class="text-muted">
                        Acceso total a todos los módulos del sistema, incluyendo
                        configuración de usuarios, paquetes y servicios.
                    </small>
                </div>
                <hr style="border-color:#ece9ff;">
                <div class="mb-3">
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <span class="badge rounded-pill px-3 bg-secondary">Asistente</span>
                    </div>
                    <small class="text-muted">
                        Acceso de lectura y registro de pagos. No puede crear
                        ni modificar reservas o cotizaciones.
                    </small>
                </div>
                <hr style="border-color:#ece9ff;">
                <div class="d-flex align-items-start gap-2 mt-3">
                    <i class="ti ti-lock mt-1" style="color:#534AB7;"></i>
                    <small class="text-muted">
                        La contraseña debe tener mínimo 8 caracteres.
                        El usuario podrá cambiarla desde su perfil.
                    </small>
                </div>
            </div>
        </div>
    </div>

</div>