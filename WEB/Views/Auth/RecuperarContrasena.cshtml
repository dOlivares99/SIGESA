@model WEB.Models.ViewModels.RecuperarContrasenaViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Recuperar contraseña — SIGESA</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/tabler-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
            * {
                font-family: 'Inter', sans-serif;
            }

            body {
                background: linear-gradient(135deg, #534AB7 0%, #3d3490 100%);
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .card {
                border: none;
                border-radius: 20px;
                box-shadow: 0 20px 60px rgba(0,0,0,.25);
            }

            .btn-primary {
                background: #534AB7;
                border-color: #534AB7;
            }

                .btn-primary:hover {
                    background: #4239a0;
                    border-color: #4239a0;
                }

            .form-control:focus {
                border-color: #534AB7;
                box-shadow: 0 0 0 .2rem rgba(83,74,183,.2);
            }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-sm-10 col-md-8 col-lg-5">

                <div class="text-center mb-4">
                    <h1 class="text-white fw-bold mb-1">SIGESA</h1>
                    <p class="text-white-50 small">Sala de Eventos Mónica</p>
                </div>

                <div class="card p-4 p-sm-5">
                    <div class="text-center mb-4">
                        <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                             style="width:56px;height:56px;background:#f0eeff;">
                            <i class="ti ti-lock-open" style="font-size:1.75rem;color:#534AB7;"></i>
                        </div>
                        <h5 class="fw-bold mb-1">¿Olvidaste tu contraseña?</h5>
                        <p class="text-muted small mb-0">
                            Ingresa tu correo y te enviaremos un enlace para restablecerla.
                        </p>
                    </div>

                    @if (!ViewData.ModelState.IsValid)
                    {
                        <div class="alert alert-danger py-2 mb-3" style="border-radius:10px;">
                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                            {
                                <div><i class="ti ti-alert-circle me-1"></i>@error.ErrorMessage</div>
                            }
                        </div>
                    }

                    <form asp-action="RecuperarContrasena" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-4">
                            <label class="form-label fw-medium">Correo electrónico</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white border-end-0">
                                    <i class="ti ti-mail text-muted"></i>
                                </span>
                                <input asp-for="Email" type="email"
                                       class="form-control border-start-0 ps-0"
                                       placeholder="tu@correo.com"
                                       autocomplete="email" autofocus />
                            </div>
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-2 fw-semibold">
                            <i class="ti ti-send me-1"></i> Enviar enlace de recuperación
                        </button>
                    </form>

                    <div class="text-center mt-4">
                        <a asp-controller="Auth" asp-action="Login"
                           class="text-decoration-none small" style="color:#534AB7;">
                            <i class="ti ti-arrow-left me-1"></i> Volver al inicio de sesión
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
