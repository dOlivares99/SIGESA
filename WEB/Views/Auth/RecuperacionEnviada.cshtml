@{
    Layout = null;
    var email = ViewBag.Email as string ?? "";
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Correo enviado — SIGESA</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/tabler-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
            * {
                font-family: 'Inter', sans-serif;
            }

            body {
                background: linear-gradient(135deg, #534AB7 0%, #3d3490 100%);
                min-height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
            }

            .card {
                border: none;
                border-radius: 20px;
                box-shadow: 0 20px 60px rgba(0,0,0,.25);
            }
    </style>
</head>
<body>
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-sm-10 col-md-8 col-lg-5">

                <div class="text-center mb-4">
                    <h1 class="text-white fw-bold mb-1">SIGESA</h1>
                    <p class="text-white-50 small">Sala de Eventos Mónica</p>
                </div>

                <div class="card p-4 p-sm-5 text-center">
                    <div class="mb-3">
                        <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                             style="width:64px;height:64px;background:#e6f4f0;">
                            <i class="ti ti-mail-check" style="font-size:2rem;color:#0F6E56;"></i>
                        </div>
                    </div>

                    <h5 class="fw-bold mb-2">Revisa tu correo</h5>
                    <p class="text-muted small mb-1">Enviamos un enlace de recuperación a:</p>
                    <p class="fw-semibold mb-3" style="color:#534AB7;">@email</p>
                    <p class="text-muted small mb-4" style="line-height:1.6;">
                        El enlace expira en <strong>30 minutos</strong>.
                        Si no lo ves en tu bandeja principal, revisa la carpeta de spam.
                    </p>

                    <a asp-controller="Auth" asp-action="Login"
                       class="btn btn-outline-secondary w-100">
                        <i class="ti ti-arrow-left me-1"></i> Volver al inicio de sesión
                    </a>

                    <hr class="my-4">

                    <p class="text-muted small mb-2">¿No recibiste el correo?</p>
                    <a asp-action="RecuperarContrasena"
                       class="text-decoration-none small fw-semibold" style="color:#534AB7;">
                        Volver a intentarlo
                    </a>
                </div>

            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
