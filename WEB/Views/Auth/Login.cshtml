@model WEB.Models.ViewModels.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SIGESA — Iniciar sesion</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/@@tabler/icons-webfont@latest/tabler-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        * { font-family: 'Inter', sans-serif; }
        body {
            background: linear-gradient(135deg, #534AB7 0%, #3d3490 100%);
            min-height: 100vh;
        }
        .login-card {
            border: none;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
        }
        .btn-primary { background-color: #534AB7; border-color: #534AB7; }
        .btn-primary:hover { background-color: #4239a0; border-color: #4239a0; }
        .form-control:focus { border-color: #534AB7; box-shadow: 0 0 0 0.2rem rgba(83,74,183,0.25); }
    </style>
</head>
<body class="d-flex align-items-center justify-content-center">
    <div class="login-card card p-4 p-md-5" style="width:100%;max-width:420px;">

        <div class="text-center mb-4">
            <div class="mb-2">
                <span style="font-size:2rem;">🎪</span>
            </div>
            <h4 class="fw-bold mb-1" style="color:#534AB7;">SIGESA</h4>
            <p class="text-muted small mb-0">Sistema de Gestion de Sala de Eventos</p>
            <p class="text-muted small">Sala de Eventos Monica</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger py-2">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div><i class="ti ti-alert-circle me-1"></i>@error.ErrorMessage</div>
                }
            </div>
        }

        <form asp-action="Login" asp-controller="Auth" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label asp-for="Email" class="form-label fw-medium">Correo electronico</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="ti ti-mail"></i></span>
                    <input asp-for="Email" class="form-control" placeholder="correo@ejemplo.com" />
                </div>
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label asp-for="Password" class="form-label fw-medium">Contrasena</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="ti ti-lock"></i></span>
                    <input asp-for="Password" class="form-control" placeholder="••••••••" />
                </div>
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>
            <button type="submit" class="btn btn-primary w-100 py-2 fw-medium">
                <i class="ti ti-login me-1"></i> Iniciar sesion
            </button>
        </form>

        <p class="text-center text-muted small mt-4 mb-0">
            SIGESA v1.0 &copy; 2026
        </p>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
