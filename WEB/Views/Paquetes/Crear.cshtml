@model WEB.Models.ViewModels.PaqueteFormViewModel
@{
    ViewData["Title"] = "Nuevo paquete";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="ti ti-arrow-left"></i>
    </a>
    <div>
        <h5 class="fw-bold mb-0">Nuevo paquete</h5>
        <small class="text-muted">Completa los datos del paquete</small>
    </div>
</div>

<div class="row g-4">

    <div class="col-12 col-lg-7">
        <div class="card h-100">
            <div class="card-body p-4">

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger py-2">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <div><i class="ti ti-alert-circle me-1"></i>@error.ErrorMessage</div>
                        }
                    </div>
                }

                <form asp-action="Crear" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label fw-medium">Nombre del paquete</label>
                        <input asp-for="Nombre" class="form-control" placeholder="Ej: Paquete Básico" />
                        <span asp-validation-for="Nombre" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Descripcion" class="form-label fw-medium">
                            Descripción <span class="text-muted fw-normal">(opcional)</span>
                        </label>
                        <textarea asp-for="Descripcion" class="form-control" rows="3"
                                  placeholder="Describe qué incluye el paquete..."></textarea>
                        <span asp-validation-for="Descripcion" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="PrecioBase" class="form-label fw-medium">Precio base (₡)</label>
                        <input asp-for="PrecioBase" type="number" step="0.01" min="0"
                               class="form-control" placeholder="0.00" />
                        <span asp-validation-for="PrecioBase" class="text-danger small"></span>
                    </div>
                    <div class="row g-3 mb-4">
                        <div class="col-6">
                            <label asp-for="MaxPersonas" class="form-label fw-medium">Máx. personas</label>
                            <input asp-for="MaxPersonas" type="number" min="1" class="form-control" />
                            <span asp-validation-for="MaxPersonas" class="text-danger small"></span>
                        </div>
                        <div class="col-6">
                            <label asp-for="DuracionHoras" class="form-label fw-medium">Duración (h)</label>
                            <input asp-for="DuracionHoras" type="number" min="1" max="72" class="form-control" />
                            <span asp-validation-for="DuracionHoras" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary px-4">
                            <i class="ti ti-device-floppy me-1"></i> Guardar
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                    </div>
                </form>

            </div>
        </div>
    </div>

    <div class="col-12 col-lg-5">
        <div class="card h-100" style="background:#f8f7ff;border:1.5px solid #ece9ff;">
            <div class="card-body p-4">
                <div class="d-flex align-items-center gap-2 mb-3">
                    <div class="rounded-circle d-flex align-items-center justify-content-center"
                         style="width:40px;height:40px;background:#534AB7;">
                        <i class="ti ti-package text-white"></i>
                    </div>
                    <div>
                        <div class="fw-semibold" style="color:#534AB7;">¿Qué es un paquete?</div>
                        <small class="text-muted">Guía de configuración</small>
                    </div>
                </div>
                <hr style="border-color:#ece9ff;">
                <div class="d-flex align-items-start gap-2 mb-3">
                    <i class="ti ti-circle-check mt-1" style="color:#0F6E56;"></i>
                    <div>
                        <div class="fw-medium small">Nombre único</div>
                        <small class="text-muted">Identifica el paquete en el catálogo y en las cotizaciones.</small>
                    </div>
                </div>
                <div class="d-flex align-items-start gap-2 mb-3">
                    <i class="ti ti-circle-check mt-1" style="color:#0F6E56;"></i>
                    <div>
                        <div class="fw-medium small">Precio base</div>
                        <small class="text-muted">Punto de partida del costo del evento. Se pueden agregar servicios adicionales.</small>
                    </div>
                </div>
                <div class="d-flex align-items-start gap-2 mb-3">
                    <i class="ti ti-circle-check mt-1" style="color:#0F6E56;"></i>
                    <div>
                        <div class="fw-medium small">Capacidad y duración</div>
                        <small class="text-muted">Define el máximo de personas y las horas incluidas en el paquete.</small>
                    </div>
                </div>
                <hr style="border-color:#ece9ff;">
                <div class="d-flex align-items-start gap-2 mt-3">
                    <i class="ti ti-info-circle mt-1" style="color:#534AB7;"></i>
                    <small class="text-muted">
                        El paquete quedará activo de inmediato y disponible para
                        seleccionar en nuevas cotizaciones.
                    </small>
                </div>
            </div>
        </div>
    </div>

</div>