@model WEB.Models.ViewModels.PaqueteFormViewModel
@{
    ViewData["Title"] = "Editar paquete";
}

<div class="d-flex align-items-center gap-3 mb-4">
    <a asp-action="Index" class="btn btn-sm btn-outline-secondary">
        <i class="ti ti-arrow-left"></i>
    </a>
    <div>
        <h5 class="fw-bold mb-0">Editar paquete</h5>
        <small class="text-muted">Modifica los datos del paquete</small>
    </div>
</div>

<!-- Aviso preventivo sobre cotizaciones existentes -->
<div class="alert alert-warning mb-4" style="max-width:600px;">
    <i class="ti ti-alert-triangle me-1"></i>
    <strong>Atención:</strong> Los cambios se aplicarán únicamente a cotizaciones nuevas.
    Las cotizaciones existentes conservarán los datos originales del paquete.
</div>

<div class="card" style="max-width:600px;">
    <div class="card-body p-4">

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger py-2">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div><i class="ti ti-alert-circle me-1"></i>@error.ErrorMessage</div>
                }
            </div>
        }

        <form asp-action="Editar" asp-route-id="@Model.PaqueteId" method="post">
            @Html.AntiForgeryToken()

            <div class="mb-3">
                <label asp-for="Nombre" class="form-label fw-medium">Nombre del paquete</label>
                <input asp-for="Nombre" class="form-control" />
                <span asp-validation-for="Nombre" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Descripcion" class="form-label fw-medium">
                    Descripción <span class="text-muted fw-normal">(opcional)</span>
                </label>
                <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Descripcion" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="PrecioBase" class="form-label fw-medium">Precio base (₡)</label>
                <input asp-for="PrecioBase" type="number" step="0.01" min="0" class="form-control" />
                <span asp-validation-for="PrecioBase" class="text-danger small"></span>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-6">
                    <label asp-for="MaxPersonas" class="form-label fw-medium">Máximo de personas</label>
                    <input asp-for="MaxPersonas" type="number" min="1" class="form-control" />
                    <span asp-validation-for="MaxPersonas" class="text-danger small"></span>
                </div>
                <div class="col-6">
                    <label asp-for="DuracionHoras" class="form-label fw-medium">Duración (horas)</label>
                    <input asp-for="DuracionHoras" type="number" min="1" max="72" class="form-control" />
                    <span asp-validation-for="DuracionHoras" class="text-danger small"></span>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary px-4">
                    <i class="ti ti-device-floppy me-1"></i> Guardar cambios
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>